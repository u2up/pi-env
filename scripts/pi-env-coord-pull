#!/usr/bin/env bash
set -euo pipefail

if [ -n "${PI_ENV_COORD_LIB:-}" ]; then
  # shellcheck source=/dev/null
  . "$PI_ENV_COORD_LIB"
else
  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
  # shellcheck source=pi-env-coord-lib.sh
  . "$script_dir/pi-env-coord-lib.sh"
fi

usage() {
  cat <<'USAGE'
pi-env-coord-pull - pull/rebase a coordination clone

Usage:
  pi-env-coord-pull [options] [git pull args...]

Options:
  --coord-dir DIR   Coordination clone; default: PI_ENV_COORD_DIR or .pi-env/coordination
  -h, --help        Show this help
USAGE
}

coord_dir_opt=""
git_args=()
while [ "$#" -gt 0 ]; do
  case "$1" in
    --coord-dir)
      [ "$#" -ge 2 ] || coord_die "--coord-dir requires a value"
      coord_dir_opt="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      git_args+=("$@")
      break
      ;;
    *)
      git_args+=("$1")
      shift
      ;;
  esac
done

coord_dir="$(coord_resolve_dir "$coord_dir_opt")"
cd "$coord_dir"
coord_pull_rebase "${git_args[@]}"
