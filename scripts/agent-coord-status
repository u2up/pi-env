#!/usr/bin/env bash
set -euo pipefail

if [ -n "${PI_ENV_COORD_LIB:-}" ]; then
  # shellcheck source=/dev/null
  . "$PI_ENV_COORD_LIB"
else
  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
  # shellcheck source=agent-coord-lib.sh
  . "$script_dir/agent-coord-lib.sh"
fi

usage() {
  cat <<'USAGE'
agent-coord-status - show coordination repository status and active queues

Usage:
  agent-coord-status [options]

Options:
  --coord-dir DIR   Coordination clone; default: PI_COORD_DIR or ./coordination
  -h, --help        Show this help
USAGE
}

coord_dir_opt=""
while [ "$#" -gt 0 ]; do
  case "$1" in
    --coord-dir)
      [ "$#" -ge 2 ] || coord_die "--coord-dir requires a value"
      coord_dir_opt="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      coord_die "unknown argument: $1"
      ;;
  esac
done

coord_dir="$(coord_resolve_dir "$coord_dir_opt")"
cd "$coord_dir"

printf 'Repository: %s\n' "$coord_dir"
git status --short --branch
printf '\nItems:\n'

found=0
while IFS= read -r file; do
  [ -n "$file" ] || continue
  found=1
  id="$(coord_item_value "$file" id || true)"
  status="$(coord_item_value "$file" status || true)"
  owner="$(coord_item_value "$file" owner || true)"
  priority="$(coord_item_value "$file" priority || true)"
  reviewed="$(coord_item_value "$file" reviewed || true)"
  verified="$(coord_item_value "$file" verified || true)"
  title="$(coord_item_value "$file" title || true)"
  if [ -z "$title" ]; then
    title="$(grep -m 1 '^# ' "$file" | sed 's/^# //' || true)"
  fi
  [ -n "$id" ] || id="$(basename "$file")"
  id="${id%.yaml}"
  id="${id%.yml}"
  id="${id%.md}"
  [ -n "$status" ] || status="unknown"
  [ -n "$owner" ] || owner="-"
  [ -n "$priority" ] || priority="-"
  [ -n "$reviewed" ] || reviewed="-"
  [ -n "$verified" ] || verified="-"
  [ -n "$title" ] || title="(untitled)"
  printf -- '- %s [%s] owner=%s reviewed=%s verified=%s priority=%s %s (%s)\n' \
    "$id" "$status" "$owner" "$reviewed" "$verified" "$priority" "$title" "$file"
done < <(
  while IFS= read -r file; do
    [ -n "$file" ] || continue
    if coord_item_type_uses_issue_status_dirs "$(coord_item_value "$file" type || true)"; then
      case "$(coord_item_value "$file" status || true)" in
        closed) ;;
        *) printf '%s\n' "$file" ;;
      esac
    fi
  done < <(coord_item_find_files)
)

if [ "$found" = "0" ]; then
  printf '  no open, blocked, or done items found\n'
fi
