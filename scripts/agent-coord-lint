#!/usr/bin/env bash
set -euo pipefail

if [ -n "${PI_ENV_COORD_LIB:-}" ]; then
  # shellcheck source=/dev/null
  . "$PI_ENV_COORD_LIB"
else
  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
  # shellcheck source=agent-coord-lib.sh
  . "$script_dir/agent-coord-lib.sh"
fi

usage() {
  cat <<'USAGE'
agent-coord-lint - lint coordination items and item-matched tests

Usage:
  agent-coord-lint [options]

Options:
  --coord-dir DIR            Coordination clone; default: PI_COORD_DIR or .pi-env/coordination
  --project-root DIR         Project repo containing tests/items; default: parent of coord dir
  --repo-id ID               Repo whose repo-scoped issue tests are available
  --all-repos                Validate all repo-scoped items structurally; do not require
                             repo-scoped issue tests unless --repo-id resolves one repo
  --require-done-or-closed   Fail when any issue item is not done or closed
  --warn-legacy-ids          Warn about IDs that predate the new ID format
  -h, --help                 Show this help

Checks:
  - item status and issue status-directory consistency;
  - closed issues have reviewed: true and verified: true;
  - new-format IDs match <KEY>-<TYPE>-<YYYYMMDD-HHMMSS>-<NNN>;
  - new-format filenames are ID-only stems;
  - type-code IDs match the YAML item type;
  - every item declares testable: yes or testable: no;
  - testable: yes has a matching tests/items/**/*.sh script;
  - testable: no has a non-empty testability_note;
  - items do not use legacy issue_type metadata;
  - repo manifests are valid and repo-scoped issues live under active repos;
  - issue items have embedded current/events/messages history;
  - requirement and todo items have current-state body records without
    embedded history;
  - imported FRQ/QRQ/CRQ items have non-empty source_refs;
  - every tests/items/**/*.sh script matches an existing item ID;
  - design ## Covers entries reference active requirement keys and IDs.

Issue status directories are not mirrored under tests/items. Project item
tests mirror the root item type directory:
  tests/items/issues/<item-id>.sh
  tests/items/requirements/<item-id>.sh
  tests/items/todos/<item-id>.sh

When repos/<repo_id>/issues are present, lint defaults item-matched issue test
checks to the current implementation repo resolved from --repo-id,
PI_COORD_REPO_ID, .pi-env-coordination.yaml, or Git remote registry data. --all-repos
validates every repo structurally but skips repo-scoped issue test requirements
for repos whose implementation checkout is not selected by --repo-id. Root
issues/ paths are allowed during migration with a warning; set
PI_COORD_LINT_ROOT_ISSUES=fail to reject them.
USAGE
}

coord_dir_opt=""
project_root_opt=""
repo_id_opt=""
all_repos=0
require_done_or_closed=0
warn_legacy_ids=0

while [ "$#" -gt 0 ]; do
  case "$1" in
    --coord-dir)
      [ "$#" -ge 2 ] || coord_die "--coord-dir requires a value"
      coord_dir_opt="$2"
      shift 2
      ;;
    --project-root)
      [ "$#" -ge 2 ] || coord_die "--project-root requires a value"
      project_root_opt="$2"
      shift 2
      ;;
    --repo-id)
      [ "$#" -ge 2 ] || coord_die "--repo-id requires a value"
      repo_id_opt="$2"
      shift 2
      ;;
    --all-repos)
      all_repos=1
      shift
      ;;
    --require-done-or-closed)
      require_done_or_closed=1
      shift
      ;;
    --warn-legacy-ids)
      warn_legacy_ids=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      coord_die "unknown argument: $1"
      ;;
  esac
done

coord_dir="$(coord_resolve_dir "$coord_dir_opt")"
if [ -n "$project_root_opt" ]; then
  project_root="$(coord_abs "$project_root_opt")"
else
  project_root="$(dirname "$coord_dir")"
fi

resolved_repo_id=""
repo_err=""
if [ -n "$repo_id_opt" ]; then
  resolved_repo_id="$(coord_registry_canonical_repo_id "$repo_id_opt" "$coord_dir")"
else
  repo_err="$(mktemp "${TMPDIR:-/tmp}/agent-coord-lint-repo.XXXXXX")" || coord_die "failed to create temporary file"
  if resolved_repo_id="$(cd "$project_root" && coord_resolve_repo_id "" "$coord_dir" 2>"$repo_err")"; then
    :
  else
    resolved_repo_id=""
  fi
  rm -f "$repo_err"
fi

cd "$coord_dir"

failures=0
warnings=0
items_seen=0
item_identity_seen=$'\n'

lint_fail() {
  printf 'agent-coord-lint: FAIL: %s\n' "$*" >&2
  failures=$((failures + 1))
}

lint_warn() {
  printf 'agent-coord-lint: WARN: %s\n' "$*" >&2
  warnings=$((warnings + 1))
}

for removed_path in WORKSPACE.md workspace projects; do
  if [ -e "$removed_path" ]; then
    lint_fail "$removed_path uses a removed legacy coordination layout; use root item directories"
  fi
done

if [ -d repos ]; then
  while IFS= read -r repo_dir; do
    [ -n "$repo_dir" ] || continue
    repo_id="${repo_dir#repos/}"
    manifest="$repo_dir/REPO.md"
    if ! coord_repo_id_is_valid "$repo_id"; then
      lint_fail "$repo_dir has invalid repo id directory name"
      continue
    fi
    if [ ! -f "$manifest" ]; then
      lint_fail "$repo_dir is missing REPO.md"
      continue
    fi
    manifest_repo_id="$(coord_repo_manifest_value "$manifest" repo_id || true)"
    [ -n "$manifest_repo_id" ] || lint_fail "$manifest is missing repo_id"
    if [ -n "$manifest_repo_id" ]; then
      coord_repo_id_is_valid "$manifest_repo_id" \
        || lint_fail "$manifest has invalid repo_id $manifest_repo_id"
      [ "$manifest_repo_id" = "$repo_id" ] \
        || lint_fail "$manifest repo_id $manifest_repo_id does not match directory $repo_id"
    fi
    manifest_status="$(coord_repo_manifest_value "$manifest" status || true)"
    [ -n "$manifest_status" ] || manifest_status="active"
    case "$manifest_status" in
      active|inactive|retired) ;;
      *) lint_fail "$manifest has invalid status $manifest_status" ;;
    esac
  done < <(find repos -mindepth 1 -maxdepth 1 -type d 2>/dev/null | sort)
fi

item_yaml_files() {
  while IFS= read -r file; do
    case "$file" in
      *.yaml|*.yml) printf '%s\n' "$file" ;;
    esac
  done < <(coord_item_find_files)
}

item_status_dir() {
  local file
  file="$1"
  case "$file" in
    issues/open/*|repos/*/issues/open/*) printf 'open\n' ;;
    issues/blocked/*|repos/*/issues/blocked/*) printf 'blocked\n' ;;
    issues/done/*|repos/*/issues/done/*) printf 'done\n' ;;
    issues/closed/*|repos/*/issues/closed/*) printf 'closed\n' ;;
    *) printf '\n' ;;
  esac
}

item_repo_id() {
  local file rest
  file="$1"
  case "$file" in
    repos/*/*)
      rest="${file#repos/}"
      printf '%s\n' "${rest%%/*}"
      ;;
    *) printf '\n' ;;
  esac
}

should_check_item_test() {
  local file type repo_id
  file="$1"
  type="$2"
  if coord_item_type_uses_issue_status_dirs "$type"; then
    repo_id="$(item_repo_id "$file")"
    if [ -n "$repo_id" ]; then
      [ -n "$resolved_repo_id" ] && [ "$repo_id" = "$resolved_repo_id" ]
      return
    fi
  fi
  return 0
}

item_test_subdir() {
  local type
  type="$(coord_item_type_canonical "$1")"
  case "$type" in
    functional-requirement|quality-requirement|constraint-requirement)
      printf 'requirements\n'
      ;;
    *)
      coord_item_type_dir "$type"
      ;;
  esac
}

expected_test_path() {
  local file id type subdir
  file="$1"
  id="$2"
  type="$3"
  subdir="$(item_test_subdir "$type")"
  printf '%s/tests/items/%s/%s.sh\n' "$project_root" "$subdir" "$id"
}

item_file_for_id() {
  local candidate file id_value stem
  candidate="$1"
  while IFS= read -r file; do
    [ -n "$file" ] || continue
    id_value="$(coord_item_value "$file" id || true)"
    if [ "$id_value" = "$candidate" ]; then
      printf '%s\n' "$file"
      return 0
    fi
    stem="$(basename "$file")"
    stem="${stem%.yaml}"
    stem="${stem%.yml}"
    if [ "$stem" = "$candidate" ]; then
      printf '%s\n' "$file"
      return 0
    fi
  done < <(coord_item_find_files)
  return 1
}

normalize_bool() {
  local value
  value="$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]')"
  case "$value" in
    yes|true|1) printf 'yes\n' ;;
    no|false|0) printf 'no\n' ;;
    *) printf '\n' ;;
  esac
}

item_has_source_refs() {
  local file
  file="$1"
  awk '
    /^source_refs:[[:space:]]*$/ { in_refs = 1; next }
    in_refs && /^[^[:space:]-]/ { in_refs = 0 }
    in_refs && /^[[:space:]]*-[[:space:]]*[^[:space:]]/ { found = 1 }
    END { exit found ? 0 : 1 }
  ' "$file"
}

item_is_imported_requirement() {
  local file type
  file="$1"
  type="$2"
  case "$(coord_item_type_canonical "$type")" in
    functional-requirement|quality-requirement|constraint-requirement) ;;
    *) return 1 ;;
  esac
  grep -Eiq 'Imported[[:space:]]+(from|requirement)|REQUIREMENTS\.md|USE_CASES\.md|source_refs:' "$file"
}

item_has_top_level_field() {
  local file name
  file="$1"
  name="$2"
  grep -Eq "^${name}:" "$file"
}

item_has_nonempty_top_level_body() {
  local file
  file="$1"
  awk '
    /^body:[[:space:]]*\|-/ { in_body = 1; next }
    in_body && /^[^[:space:]]/ { in_body = 0 }
    in_body && /^[[:space:]]+[^[:space:]]/ { found = 1 }
    END { exit found ? 0 : 1 }
  ' "$file"
}

while IFS= read -r file; do
  [ -n "$file" ] || continue
  items_seen=$((items_seen + 1))

  id="$(coord_item_value "$file" id || true)"
  type="$(coord_item_value "$file" type || true)"
  status="$(coord_item_value "$file" status || true)"
  reviewed="$(coord_item_value "$file" reviewed || true)"
  verified="$(coord_item_value "$file" verified || true)"
  testable_raw="$(coord_item_value "$file" testable || true)"
  testability_note="$(coord_item_value "$file" testability_note || true)"
  requirement_key="$(coord_item_value "$file" requirement_key || true)"
  requirement_class="$(coord_item_value "$file" requirement_class || true)"
  requirement_kind="$(coord_item_value "$file" requirement_kind || true)"
  requirement_domain="$(coord_item_value "$file" domain || true)"

  [ -n "$id" ] || lint_fail "$file is missing id"
  [ -n "$type" ] || lint_fail "$file is missing type"
  [ -n "$status" ] || lint_fail "$file is missing status"
  if item_has_top_level_field "$file" issue_type; then
    lint_fail "$file uses legacy issue_type metadata; use category"
  fi

  stem="$(basename "$file")"
  stem="${stem%.yaml}"
  stem="${stem%.yml}"
  if [ -n "$id" ]; then
    identity_key="$id"
  else
    identity_key="$stem"
  fi
  case "$item_identity_seen" in
    *$'\n'"$identity_key"$'\n'*)
      lint_fail "$file duplicates item id $identity_key"
      ;;
    *)
      item_identity_seen="${item_identity_seen}${identity_key}"$'\n'
      ;;
  esac

  if printf '%s' "$id" | grep -Eq '^[A-Z0-9]+-[A-Z0-9]{1,4}-[0-9]{8}-[0-9]{6}-[0-9]{3}$'; then
    if [ "$stem" != "$id" ]; then
      lint_fail "$file filename stem must equal new-format id $id"
    fi
    id_code="$(printf '%s' "$id" | cut -d- -f2)"
    expected_code="$(coord_item_type_code "$type")"
    if [ "$id_code" != "$expected_code" ]; then
      lint_fail "$file id type code $id_code does not match type $type ($expected_code)"
    fi
  elif [ "$warn_legacy_ids" = "1" ]; then
    lint_warn "$file uses legacy item id $id"
  fi

  canonical_type="$(coord_item_type_canonical "$type")"
  case "$canonical_type" in
    functional-requirement|quality-requirement|constraint-requirement)
      case "$file" in
        requirements/*.yaml|requirements/*.yml)
          ;;
        *) lint_fail "$file requirement item must live under the root requirements directory" ;;
      esac
      if [ -z "$(coord_trim "$requirement_key")" ]; then
        lint_fail "$file requirement item is missing requirement_key"
      fi
      if [ -z "$(coord_trim "$requirement_kind")" ]; then
        lint_fail "$file requirement item is missing requirement_kind"
      fi
      if [ -z "$(coord_trim "$requirement_domain")" ]; then
        lint_fail "$file requirement item is missing domain"
      fi
      case "$canonical_type:$requirement_class" in
        functional-requirement:functional|quality-requirement:quality|constraint-requirement:constraint)
          ;;
        *) lint_fail "$file requirement_class $requirement_class does not match type $type" ;;
      esac
      item_has_nonempty_top_level_body "$file" \
        || lint_fail "$file requirement item is missing non-empty top-level body"
      for history_field in current events messages; do
        if item_has_top_level_field "$file" "$history_field"; then
          lint_fail "$file requirement item must not contain top-level $history_field history"
        fi
      done
      ;;
    requirement)
      lint_fail "$file uses removed generic requirement type; use functional-requirement, quality-requirement, or constraint-requirement"
      ;;
    todo)
      case "$file" in
        todos/*.yaml|todos/*.yml)
          ;;
        *) lint_fail "$file todo item must live under the root todos directory" ;;
      esac
      item_has_nonempty_top_level_body "$file" \
        || lint_fail "$file todo item is missing non-empty top-level body"
      for history_field in current events messages; do
        if item_has_top_level_field "$file" "$history_field"; then
          lint_fail "$file todo item must not contain top-level $history_field history"
        fi
      done
      ;;
  esac

  if coord_item_type_uses_issue_status_dirs "$type"; then
    item_has_top_level_field "$file" current \
      || lint_fail "$file issue item is missing current history pointer"
    item_has_top_level_field "$file" events \
      || lint_fail "$file issue item is missing events history"
    item_has_top_level_field "$file" messages \
      || lint_fail "$file issue item is missing messages history"
    repo_id="$(item_repo_id "$file")"
    if [ -n "$repo_id" ]; then
      if ! coord_repo_id_is_valid "$repo_id"; then
        lint_fail "$file is under invalid repo id $repo_id"
      elif [ ! -f "repos/$repo_id/REPO.md" ]; then
        lint_fail "$file is under unregistered repo id $repo_id"
      else
        repo_manifest_id="$(coord_repo_manifest_value "repos/$repo_id/REPO.md" repo_id || true)"
        repo_manifest_status="$(coord_repo_manifest_value "repos/$repo_id/REPO.md" status || true)"
        [ -n "$repo_manifest_status" ] || repo_manifest_status="active"
        [ "$repo_manifest_id" = "$repo_id" ] \
          || lint_fail "$file repo manifest id $repo_manifest_id does not match $repo_id"
        [ "$repo_manifest_status" = "active" ] \
          || lint_fail "$file is under non-active repo id $repo_id (status: $repo_manifest_status)"
      fi
    else
      case "$file" in
        issues/*)
          if [ "${PI_COORD_LINT_ROOT_ISSUES:-warn}" = "fail" ]; then
            lint_fail "$file uses root issues/ during repo-scope migration"
          else
            lint_warn "$file uses root issues/ during repo-scope migration"
          fi
          ;;
      esac
    fi

    dir_status="$(item_status_dir "$file")"
    if [ -z "$dir_status" ]; then
      lint_fail "$file issue item is not under a valid issues status directory"
    elif [ "$dir_status" = "open" ]; then
      case "$status" in
        open|claimed) ;;
        *) lint_fail "$file status $status does not match issues/open" ;;
      esac
    elif [ "$status" != "$dir_status" ]; then
      lint_fail "$file status $status does not match issues/$dir_status"
    fi

    if [ "$require_done_or_closed" = "1" ]; then
      case "$status" in
        done|closed) ;;
        *) lint_fail "$file is not done or closed (status: $status)" ;;
      esac
    fi

    if [ "$status" = "closed" ]; then
      [ "$(normalize_bool "$reviewed")" = "yes" ] \
        || lint_fail "$file is closed but reviewed is not true"
      [ "$(normalize_bool "$verified")" = "yes" ] \
        || lint_fail "$file is closed but verified is not true"
    fi
  fi

  testable="$(normalize_bool "$testable_raw")"
  if [ -z "$testable" ]; then
    lint_fail "$file must declare testable: yes or testable: no"
  elif [ "$testable" = "yes" ]; then
    if should_check_item_test "$file" "$type"; then
      expected_test="$(expected_test_path "$file" "$id" "$type")"
      if [ ! -f "$expected_test" ]; then
        lint_fail "$file is testable but missing $expected_test"
      elif [ ! -x "$expected_test" ]; then
        lint_fail "$expected_test must be executable"
      fi
    fi
  else
    if [ -z "$(coord_trim "$testability_note")" ]; then
      lint_fail "$file has testable: no but no testability_note"
    fi
  fi

  if item_is_imported_requirement "$file" "$type" && ! item_has_source_refs "$file"; then
    lint_fail "$file is an imported requirement but has no source_refs entries"
  fi
done < <(item_yaml_files)

items_tests_dir="$project_root/tests/items"
if [ -d "$items_tests_dir" ]; then
  while IFS= read -r test_file; do
    [ -n "$test_file" ] || continue
    test_id="$(basename "$test_file")"
    test_id="${test_id%.sh}"
    item_file="$(item_file_for_id "$test_id" || true)"
    if [ -z "$item_file" ]; then
      lint_fail "$test_file does not match any coordination item id"
      continue
    fi
    item_type="$(coord_item_value "$item_file" type || true)"
    if ! should_check_item_test "$item_file" "$item_type"; then
      lint_fail "$test_file matches repo-scoped item outside selected repo; use --repo-id for that implementation repo"
      continue
    fi
    expected_test="$(expected_test_path "$item_file" "$test_id" "$item_type")"
    if [ "$test_file" != "$expected_test" ]; then
      lint_fail "$test_file must live at $expected_test"
    fi
  done < <(find "$items_tests_dir" -type f -name '*.sh' 2>/dev/null | sort)
fi

coverage_generator="$project_root/scripts/agent-coord-generate-requirements-coverage"
if [ ! -x "$coverage_generator" ]; then
  coverage_generator="$(command -v agent-coord-generate-requirements-coverage || true)"
fi
if [ -n "$coverage_generator" ] && [ -x "$coverage_generator" ] && [ -d "$project_root/designs" ]; then
  coverage_output="$("$coverage_generator" \
    --coordination-dir "$coord_dir" \
    --designs-dir "$project_root/designs" \
    --check 2>&1)" || {
      if [ -n "$coverage_output" ]; then
        while IFS= read -r line; do
          [ -n "$line" ] || continue
          lint_fail "requirements coverage: $line"
        done <<EOF
$coverage_output
EOF
      else
        lint_fail "requirements coverage check failed"
      fi
    }
fi

if [ "$failures" -gt 0 ]; then
  printf 'agent-coord-lint: %d failure(s), %d warning(s), %d item(s) checked\n' \
    "$failures" "$warnings" "$items_seen" >&2
  exit 1
fi

printf 'agent-coord-lint: ok (%d item(s), %d warning(s))\n' \
  "$items_seen" "$warnings"
