#!/usr/bin/env bash
set -euo pipefail

if [ -n "${PI_ENV_COORD_LIB:-}" ]; then
  # shellcheck source=/dev/null
  . "$PI_ENV_COORD_LIB"
else
  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
  # shellcheck source=agent-coord-lib.sh
  . "$script_dir/agent-coord-lib.sh"
fi

usage() {
  cat <<'USAGE'
agent-coord-new - create a templated coordination item

Usage:
  agent-coord-new [options] "Item title"

Options:
  --coord-dir DIR          Coordination clone; default: PI_COORD_DIR or .pi-env/coordination
  --project KEY            Removed legacy option; root-layout items only
  --project-key KEY        Project key portion of generated IDs
  --repo-id ID             Create the item under repos/{repo_id}
  --workspace-item         Removed legacy option; root-layout items only
  --type TYPE              Item type; default: issue
  --category CATEGORY      Optional issue category: bug, feature-request, task, question, improvement, ...
  --status STATUS          Initial status; default: open for issues, active otherwise
  --priority VALUE         Priority value; default: medium
  --owner ID               Initial owner; default: empty
  --agent-id ID            Event actor's agent ID; default: PI_COORD_AGENT_ID or USER
  --role ROLE              Coordination role; default: PI_COORD_ROLE
  --testable yes|no        Whether an item-matched test is required; default: yes
  --testability-note TEXT  Required rationale when --testable no
  --id ID                  Explicit item ID; default: timestamp ID with type code
  -h, --help               Show this help

Items are created in the project-root layout only: PROJECT.md plus root item
folders such as issues/, requirements/, todos/, decisions/, and notes/. The
item key is resolved from --project-key, stored project metadata,
PI_COORD_PROJECT_KEY, or a derived project name. It is uppercased and all
non-alphanumeric characters are removed for item IDs.

Generated IDs use:
  <PROJECTKEY>-<TYPECODE>-<YYYYMMDD-HHMMSS>-<NNN>

The NNN collision/order suffix starts at 001 for each timestamp. Filenames
use the item ID only, for example PIENV-ISS-20260607-204155-001.yaml.
USAGE
}

coord_dir_opt=""
project_id_key_arg=""
project_id_key_env="${PI_COORD_PROJECT_KEY:-}"
repo_id_arg=""
item_type="issue"
category=""
status_arg=""
priority="medium"
owner=""
agent_id="$(coord_default_agent)"
role="$(coord_default_role)"
testable="yes"
testability_note=""
explicit_id=""
title_parts=()

while [ "$#" -gt 0 ]; do
  case "$1" in
    --coord-dir)
      [ "$#" -ge 2 ] || coord_die "--coord-dir requires a value"
      coord_dir_opt="$2"
      shift 2
      ;;
    --project)
      coord_die "--project has been removed; create root-layout items and use --project-key for ID prefixes"
      ;;
    --project-key)
      [ "$#" -ge 2 ] || coord_die "--project-key requires a value"
      project_id_key_arg="$2"
      shift 2
      ;;
    --repo-id)
      [ "$#" -ge 2 ] || coord_die "--repo-id requires a value"
      repo_id_arg="$2"
      shift 2
      ;;
    --workspace-item)
      coord_die "--workspace-item has been removed; create root-layout items"
      ;;
    --type)
      [ "$#" -ge 2 ] || coord_die "--type requires a value"
      item_type="$2"
      shift 2
      ;;
    --category)
      [ "$#" -ge 2 ] || coord_die "--category requires a value"
      category="$2"
      shift 2
      ;;
    --issue-type)
      coord_die "--issue-type has been removed; use --category"
      ;;
    --status)
      [ "$#" -ge 2 ] || coord_die "--status requires a value"
      status_arg="$2"
      shift 2
      ;;
    --priority)
      [ "$#" -ge 2 ] || coord_die "--priority requires a value"
      priority="$2"
      shift 2
      ;;
    --owner)
      [ "$#" -ge 2 ] || coord_die "--owner requires a value"
      owner="$2"
      shift 2
      ;;
    --agent-id)
      [ "$#" -ge 2 ] || coord_die "--agent-id requires a value"
      agent_id="$2"
      shift 2
      ;;
    --role)
      [ "$#" -ge 2 ] || coord_die "--role requires a value"
      role="$2"
      shift 2
      ;;
    --testable)
      [ "$#" -ge 2 ] || coord_die "--testable requires a value"
      testable="$(printf '%s' "$2" | tr '[:upper:]' '[:lower:]')"
      shift 2
      ;;
    --testability-note)
      [ "$#" -ge 2 ] || coord_die "--testability-note requires a value"
      testability_note="$2"
      shift 2
      ;;
    --id)
      [ "$#" -ge 2 ] || coord_die "--id requires a value"
      explicit_id="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --*)
      coord_die "unknown option: $1"
      ;;
    *)
      title_parts+=("$1")
      shift
      ;;
  esac
done

if [ "${#title_parts[@]}" -eq 0 ]; then
  coord_die "item title is required"
fi

case "$testable" in
  yes|true|1)
    testable="yes"
    ;;
  no|false|0)
    testable="no"
    ;;
  *)
    coord_die "--testable must be yes or no"
    ;;
esac

if [ "$testable" = "no" ] && [ -z "$(coord_trim "$testability_note")" ]; then
  coord_die "--testability-note is required when --testable no"
fi

if [ -z "$(coord_trim "$item_type")" ]; then
  coord_die "--type must not be empty"
fi
raw_item_type_lc="$(printf '%s' "$item_type" | tr '[:upper:]' '[:lower:]')"
case "$raw_item_type_lc" in
  task|tasks)
    coord_die "--type $item_type is not a coordination item type; use --type issue --category task"
    ;;
  requirement|requirements|req|reqs)
    coord_die "generic requirement items have been removed; use --type functional-requirement, quality-requirement, or constraint-requirement"
    ;;
  tdo)
    coord_die "--type tdo is not supported; use --type todo"
    ;;
esac

if [ -z "$status_arg" ]; then
  if coord_item_type_uses_issue_status_dirs "$item_type"; then
    status_arg="open"
  else
    status_arg="active"
  fi
fi

if coord_item_type_uses_issue_status_dirs "$item_type" && [ "$status_arg" != "open" ]; then
  coord_die "new issue items must start with --status open"
fi

item_type="$(coord_item_type_canonical "$item_type")"
if [ -n "$(coord_trim "$category")" ]; then
  if ! coord_item_type_uses_issue_status_dirs "$item_type"; then
    coord_die "--category is only valid for issue items"
  fi
  category="$(coord_category_canonical "$category")"
  [ -n "$category" ] || coord_die "--category produced an empty category"
fi
type_dir="$(coord_item_type_dir "$item_type")"
title="${title_parts[*]}"
coord_dir="$(coord_resolve_dir "$coord_dir_opt")"
cd "$coord_dir"

if [ -n "$repo_id_arg" ]; then
  repo_id="$(coord_registry_canonical_repo_id "$repo_id_arg" "$coord_dir")"
  metadata_file="repos/$repo_id/REPO.md"
  [ -f "$metadata_file" ] || coord_die "repo manifest missing: $metadata_file"
  if coord_item_type_uses_issue_status_dirs "$item_type"; then
    item_root="repos/$repo_id/$type_dir/open"
  else
    item_root="repos/$repo_id/$type_dir"
  fi
elif coord_item_type_uses_issue_status_dirs "$item_type" && [ -d repos ]; then
  coord_die "new issue items must specify --repo-id in repo-scoped coordination domains"
elif ! coord_write_root_items_by_default; then
  coord_die "no project-root layout found; initialize with agent-coord-init and create root item directories"
fi

created="$(coord_timestamp_iso)"
actor="$(coord_effective_actor "$agent_id" "$role")"

if true; then
  if [ -z "$repo_id_arg" ]; then
    if coord_item_type_uses_issue_status_dirs "$item_type"; then
      item_root="$type_dir/open"
    else
      item_root="$type_dir"
    fi
    metadata_file="PROJECT.md"
  fi
  stored_key="$(coord_metadata_item_key "$metadata_file")"
  if [ -n "$project_id_key_arg" ] && [ -n "$stored_key" ]; then
    if [ "$(coord_project_id_prefix "$project_id_key_arg")" != "$(coord_project_id_prefix "$stored_key")" ]; then
      coord_die "--project-key conflicts with stored project item_key: $stored_key"
    fi
  fi
  if [ -n "$project_id_key_arg" ]; then
    project_id_key="$project_id_key_arg"
  elif [ -n "$stored_key" ]; then
    project_id_key="$stored_key"
  elif [ -n "$project_id_key_env" ]; then
    project_id_key="$project_id_key_env"
  else
    project_id_key="$(coord_workspace_dir_key .)"
  fi
  id_prefix="$(coord_project_id_prefix "$project_id_key")"
  project_value="$(coord_metadata_value "$metadata_file" project)"
  if [ -z "$project_value" ] && [ -n "$repo_id_arg" ]; then
    project_value="$repo_id"
  fi
  if [ -z "$project_value" ]; then
    project_value="$(coord_sanitize_path_part "$(basename "$(pwd -P)")")"
  fi
  [ -n "$project_value" ] || project_value="project"
fi

mkdir -p "$item_root"

if [ -n "$explicit_id" ]; then
  item_id="$explicit_id"
  if coord_item_id_exists "$item_id"; then
    coord_die "item already exists: $item_id"
  fi
else
  item_id="$(coord_next_item_id "$id_prefix" "$item_type" "$(coord_timestamp_id)")"
fi

path="$item_root/$item_id.yaml"
if [ -e "$path" ]; then
  coord_die "item already exists: $path"
fi

requirement_metadata=""
case "$item_type" in
  functional-requirement)
    requirement_metadata="requirement_key: $item_id
requirement_class: functional
requirement_kind: detailed-behavior
domain: requirements
"
    ;;
  quality-requirement)
    requirement_metadata="requirement_key: $item_id
requirement_class: quality
requirement_kind: quality
domain: requirements
"
    ;;
  constraint-requirement)
    requirement_metadata="requirement_key: $item_id
requirement_class: constraint
requirement_kind: constraint
domain: requirements
"
    ;;
  requirement)
    requirement_metadata="requirement_key: $item_id
requirement_class: legacy
requirement_kind: legacy
domain: requirements
"
    ;;
esac

case "$item_type" in
  functional-requirement|quality-requirement|constraint-requirement|requirement|todo)
    cat >"$path" <<EOF_ITEM
schema: coordination-item/v1
id: $item_id
type: $item_type
status: $status_arg
project: $project_value
title: $(coord_yaml_scalar "$title")
owner: $(coord_yaml_scalar "$owner")
priority: $priority
created: $created
updated: $created
done: null
closed: null
reviewed: false
verified: false
${requirement_metadata}testable: $testable
testability_note: $(coord_yaml_scalar "$testability_note")
related: []
body: |-
  # $title

  ## Context

  ## Acceptance criteria

  - [ ] Define acceptance criteria.
EOF_ITEM
    ;;
  *)
    cat >"$path" <<EOF_ITEM
schema: coordination-item/v1
id: $item_id
type: $item_type
category: $(coord_yaml_scalar "$category")
status: $status_arg
project: $project_value
title: $(coord_yaml_scalar "$title")
owner: $(coord_yaml_scalar "$owner")
priority: $priority
created: $created
updated: $created
done: null
closed: null
reviewed: false
verified: false
${requirement_metadata}testable: $testable
testability_note: $(coord_yaml_scalar "$testability_note")
related: []
current:
  event: evt-0001
  message: msg-0001
events:
  - id: evt-0001
    type: opened
    at: $created
    actor:
      id: $(coord_yaml_scalar "$agent_id")
      role: $(coord_yaml_scalar "$role")
    message: msg-0001
messages:
  - id: msg-0001
    event: evt-0001
    body: |-
      # $title

      ## Context

      ## Acceptance criteria

      - [ ] Define acceptance criteria.
EOF_ITEM
    ;;
esac

coord_note "created item: $path by $actor"
printf '%s\n' "$path"
