#!/usr/bin/env bash
set -euo pipefail

if [ -n "${PI_ENV_COORD_LIB:-}" ]; then
  # shellcheck source=/dev/null
  . "$PI_ENV_COORD_LIB"
else
  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
  # shellcheck source=agent-coord-lib.sh
  . "$script_dir/agent-coord-lib.sh"
fi

usage() {
  cat <<'USAGE'
agent-coord-new - create a templated coordination item

Usage:
  agent-coord-new [options] "Item title"

Options:
  --coord-dir DIR     Coordination clone; default: PI_COORD_DIR or ./coordination
  --project KEY       Create under projects/<key>/issues/open
  --project-key KEY   Item ID prefix; overrides stored/default project key
  --workspace-item    Create under workspace/issues/open
  --type TYPE         Item type; default: issue
  --priority VALUE    Priority value; default: medium
  --owner ID          Initial owner; default: empty
  --agent-id ID       Event actor's agent ID; default: PI_COORD_AGENT_ID or USER
  --role ROLE         Coordination role; default: PI_COORD_ROLE
  --id ID             Explicit item ID; default: timestamp ID
  -h, --help          Show this help

If --project is omitted, PI_COORD_PROJECT is used when set. Otherwise the
item is created as a workspace-level item. The item key is resolved from
--project-key, stored project/workspace metadata, PI_COORD_PROJECT_KEY, or
a derived project/workspace name. It is uppercased and all non-alphanumeric
characters are removed for item IDs.
USAGE
}

coord_dir_opt=""
project_key="${PI_COORD_PROJECT:-}"
project_id_key_arg=""
project_id_key_env="${PI_COORD_PROJECT_KEY:-}"
workspace_item=0
item_type="issue"
priority="medium"
owner=""
agent_id="$(coord_default_agent)"
role="$(coord_default_role)"
explicit_id=""
title_parts=()

while [ "$#" -gt 0 ]; do
  case "$1" in
    --coord-dir)
      [ "$#" -ge 2 ] || coord_die "--coord-dir requires a value"
      coord_dir_opt="$2"
      shift 2
      ;;
    --project)
      [ "$#" -ge 2 ] || coord_die "--project requires a value"
      project_key="$2"
      workspace_item=0
      shift 2
      ;;
    --project-key)
      [ "$#" -ge 2 ] || coord_die "--project-key requires a value"
      project_id_key_arg="$2"
      shift 2
      ;;
    --workspace-item)
      workspace_item=1
      project_key=""
      shift
      ;;
    --type)
      [ "$#" -ge 2 ] || coord_die "--type requires a value"
      item_type="$2"
      shift 2
      ;;
    --priority)
      [ "$#" -ge 2 ] || coord_die "--priority requires a value"
      priority="$2"
      shift 2
      ;;
    --owner)
      [ "$#" -ge 2 ] || coord_die "--owner requires a value"
      owner="$2"
      shift 2
      ;;
    --agent-id)
      [ "$#" -ge 2 ] || coord_die "--agent-id requires a value"
      agent_id="$2"
      shift 2
      ;;
    --role)
      [ "$#" -ge 2 ] || coord_die "--role requires a value"
      role="$2"
      shift 2
      ;;
    --id)
      [ "$#" -ge 2 ] || coord_die "--id requires a value"
      explicit_id="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      title_parts+=("$1")
      shift
      ;;
  esac
done

if [ "${#title_parts[@]}" -eq 0 ]; then
  coord_die "item title is required"
fi

title="${title_parts[*]}"
coord_dir="$(coord_resolve_dir "$coord_dir_opt")"
cd "$coord_dir"

if [ -z "$project_key" ]; then
  workspace_item=1
fi

created="$(coord_timestamp_iso)"
actor="$(coord_effective_actor "$agent_id" "$role")"

if [ "$workspace_item" = "1" ]; then
  item_root="workspace/issues/open"
  project_value="workspace"
  metadata_file="WORKSPACE.md"
  stored_key="$(coord_metadata_item_key "$metadata_file")"
  if [ -n "$project_id_key_arg" ] && [ -n "$stored_key" ]; then
    if [ "$(coord_project_id_prefix "$project_id_key_arg")" != "$(coord_project_id_prefix "$stored_key")" ]; then
      coord_die "--project-key conflicts with stored workspace item_key: $stored_key"
    fi
  fi
  if [ -n "$project_id_key_arg" ]; then
    project_id_key="$project_id_key_arg"
  elif [ -n "$stored_key" ]; then
    project_id_key="$stored_key"
  elif [ -n "$project_id_key_env" ]; then
    project_id_key="$project_id_key_env"
  else
    project_id_key="$(coord_workspace_dir_key .)"
  fi
  id_prefix="$(coord_project_id_prefix "$project_id_key")"
  if [ ! -f "$metadata_file" ]; then
    cat >"$metadata_file" <<EOF_WORKSPACE
---
workspace: workspace
item_key: $id_prefix
created: $created
---

# Workspace

- Workspace item key: $id_prefix
EOF_WORKSPACE
  fi
else
  project_dir="$(coord_sanitize_path_part "$project_key")"
  [ -n "$project_dir" ] || coord_die "project key produced an empty path"
  item_root="projects/$project_dir/issues/open"
  project_value="$project_dir"
  metadata_file="projects/$project_dir/PROJECT.md"
  stored_key="$(coord_metadata_item_key "$metadata_file")"
  if [ -n "$project_id_key_arg" ] && [ -n "$stored_key" ]; then
    if [ "$(coord_project_id_prefix "$project_id_key_arg")" != "$(coord_project_id_prefix "$stored_key")" ]; then
      coord_die "--project-key conflicts with stored project item_key: $stored_key"
    fi
  fi
  if [ -n "$project_id_key_arg" ]; then
    project_id_key="$project_id_key_arg"
  elif [ -n "$stored_key" ]; then
    project_id_key="$stored_key"
  elif [ -n "$project_id_key_env" ]; then
    project_id_key="$project_id_key_env"
  else
    project_id_key="$project_key"
  fi
  id_prefix="$(coord_project_id_prefix "$project_id_key")"
  if [ ! -f "$metadata_file" ]; then
    mkdir -p "$(dirname "$metadata_file")"
    cat >"$metadata_file" <<EOF_PROJECT
---
project: $project_dir
item_key: $id_prefix
created: $created
---

# Project: $project_dir

- Project item key: $id_prefix
- Source name: $project_key
EOF_PROJECT
  fi
fi

mkdir -p "$item_root"
slug="$(coord_slug "$title")"

if [ -n "$explicit_id" ]; then
  item_id="$explicit_id"
else
  item_id="$id_prefix-$(coord_timestamp_id)"
fi

path="$item_root/$item_id-$slug.yaml"
if [ -e "$path" ]; then
  coord_die "item already exists: $path"
fi

cat >"$path" <<EOF_ITEM
schema: coordination-item/v1
id: $item_id
type: $item_type
status: open
project: $project_value
title: $(coord_yaml_scalar "$title")
owner: $(coord_yaml_scalar "$owner")
priority: $priority
created: $created
updated: $created
done: null
closed: null
reviewed: false
verified: false
related: []
current:
  event: evt-0001
  message: msg-0001
events:
  - id: evt-0001
    type: opened
    at: $created
    actor:
      id: $(coord_yaml_scalar "$agent_id")
      role: $(coord_yaml_scalar "$role")
    message: msg-0001
messages:
  - id: msg-0001
    event: evt-0001
    body: |-
      # $title

      ## Context

      ## Acceptance criteria

      - [ ] Define acceptance criteria.
EOF_ITEM

coord_note "created item: $path by $actor"
printf '%s\n' "$path"
