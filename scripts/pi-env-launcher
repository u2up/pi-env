#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
pi-env - run Pi through the pi-env launcher

Usage:
  pi-env [--runtime host|nix|auto] [--flake REF] [pi args...]
  pi-env [--runtime host|nix|auto] [--flake REF] --raw -- [pi args...]
  pi-env-shell [--runtime host|nix|auto] [--flake REF] [shell args...]
  pi-env --help
  pi-env-shell --help

Default pi-env mode starts Pi through pi-env-bwrap with the standard tools,
--continue, and role-manager auto-loading policy.
Raw pi-env mode delegates to pi-env-bwrap for fully custom Pi arguments.
pi-env-shell selects the same runtime as pi-env, then asks pi-env-bwrap to enter
sandbox shell mode instead of starting Pi. With no Bash arguments it starts an
interactive login shell and requires both stdin and stdout to be TTYs. In non-TTY
contexts, pass explicit non-interactive Bash arguments such as -- -lc 'pwd'.

Runtime modes:
  host  Use host-installed tools inside the Bubblewrap sandbox. This is the
        default for direct checkout launches and is not Nix-pinned.
  nix   Use the reproducible Nix-backed runtime, entering nix develop when
        the launcher is not already wired to Nix-provided pi-env commands.
  auto  Use available pi-env commands first, then fall back to nix develop.

Select a mode with --runtime or PI_ENV_RUNTIME; the CLI option wins.
USAGE
}

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
command_name="${0##*/}"
shell_mode=0
if [ "$command_name" = "pi-env-shell" ] || [ "${PI_ENV_SHELL_MODE:-0}" = "1" ]; then
  shell_mode=1
fi
checkout_root="$(cd "$script_dir/.." && pwd -P)"
flake_ref="${PI_ENV_FLAKE:-$checkout_root}"
flake_selector_set=0
if [ "${PI_ENV_FLAKE+x}" = "x" ]; then
  flake_selector_set=1
fi
runtime_mode=""
runtime_selector_set=0
runtime_cli_set=0
if [ "${PI_ENV_RUNTIME+x}" = "x" ]; then
  runtime_mode="$PI_ENV_RUNTIME"
  runtime_selector_set=1
fi
raw=0
args=()

while [ "$#" -gt 0 ]; do
  case "$1" in
    -h|--help)
      usage
      exit 0
      ;;
    --raw)
      raw=1
      shift
      if [ "${1:-}" = "--" ]; then
        shift
      fi
      break
      ;;
    --flake)
      shift
      if [ "$#" -eq 0 ]; then
        echo "pi-env: --flake requires an argument" >&2
        exit 2
      fi
      flake_ref="$1"
      flake_selector_set=1
      shift
      ;;
    --flake=*)
      flake_ref="${1#--flake=}"
      flake_selector_set=1
      shift
      ;;
    --runtime)
      shift
      if [ "$#" -eq 0 ]; then
        echo "pi-env: --runtime requires an argument" >&2
        exit 2
      fi
      runtime_mode="$1"
      runtime_selector_set=1
      runtime_cli_set=1
      shift
      ;;
    --runtime=*)
      runtime_mode="${1#--runtime=}"
      runtime_selector_set=1
      runtime_cli_set=1
      shift
      ;;
    --)
      shift
      break
      ;;
    *)
      break
      ;;
  esac
done

args+=("$@")

if [ "$runtime_selector_set" = "0" ]; then
  if [ "${PI_ENV_HOST_RUNTIME:-0}" = "1" ]; then
    runtime_mode="host"
  elif [ -n "${PI_ENV_PI_ENV_BWRAP:-}" ]; then
    runtime_mode="auto"
  else
    runtime_mode="host"
  fi
fi

case "$runtime_mode" in
  host|nix|auto) ;;
  *)
    if [ "$runtime_cli_set" = "1" ]; then
      echo "pi-env: invalid --runtime value: $runtime_mode" >&2
    else
      echo "pi-env: invalid PI_ENV_RUNTIME value: $runtime_mode" >&2
    fi
    echo "pi-env: expected one of: host, nix, auto" >&2
    exit 2
    ;;
esac

default_startup_args() {
  local tools="${PI_ENV_BWRAP_COMPILED_DEFAULT_TOOLS:-read,bash,edit,write,grep,find,ls}"
  if [ -n "${PI_ENV_BWRAP_DEFAULT_TOOLS:-}" ]; then
    tools="$PI_ENV_BWRAP_DEFAULT_TOOLS"
  fi

  local role_manager_package="${PI_ENV_ROLE_MANAGER_PACKAGE:-}"
  if [ "${PI_ENV_ROLE_MANAGER_AUTO:-1}" != "0" ]; then
    if [ -z "$role_manager_package" ]; then
      local checkout_role_manager="$checkout_root/role-manager"
      if [ -e "$checkout_role_manager" ]; then
        role_manager_package="$checkout_role_manager"
      fi
    fi
    if [ -n "$role_manager_package" ] && [ -e "$role_manager_package" ]; then
      printf '%s\0' --tools "$tools" --continue -e "$role_manager_package"
      return 0
    fi
  fi
  printf '%s\0' --tools "$tools" --continue
}

exec_pi_bwrap_default() {
  local pi_bwrap="$1"
  local default_args=()
  while IFS= read -r -d '' arg; do
    default_args+=("$arg")
  done < <(default_startup_args)
  exec "$pi_bwrap" "${default_args[@]}" "${args[@]}"
}

exec_host_runtime() {
  local host_pi_bwrap="$script_dir/pi-env-bwrap"
  export PI_ENV_HOST_RUNTIME=1
  unset PI_ENV_RUNTIME_PATH
  export PI_ENV_PI_ENV_BWRAP="$host_pi_bwrap"
  if [ "$shell_mode" = "1" ]; then
    exec "$host_pi_bwrap" --shell -- "${args[@]}"
  elif [ "$raw" = "1" ]; then
    exec "$host_pi_bwrap" -- "${args[@]}"
  fi
  exec_pi_bwrap_default "$host_pi_bwrap"
}

resolve_project_root() {
  local root=""
  root="$(git rev-parse --show-toplevel 2>/dev/null || true)"
  if [ -n "$root" ]; then
    (cd "$root" && pwd -P)
  else
    pwd -P
  fi
}

is_direct_checkout_launcher() {
  [ "$script_dir" = "$checkout_root/scripts" ] && [ -f "$checkout_root/flake.nix" ]
}

select_default_nix_flake() {
  if [ "$flake_selector_set" = "1" ]; then
    return 0
  fi

  if is_direct_checkout_launcher; then
    flake_ref="$checkout_root"
    return 0
  fi

  local project_root
  project_root="$(resolve_project_root)"
  if [ ! -f "$project_root/flake.nix" ]; then
    echo "pi-env: runtime mode 'nix' requires a target project flake." >&2
    echo "pi-env: expected flake.nix at: $project_root/flake.nix" >&2
    echo "pi-env: run from a project with flake.nix or pass --flake REF / set PI_ENV_FLAKE explicitly." >&2
    exit 2
  fi
  flake_ref="$project_root"
}

canonical_path() {
  local path="$1"
  if [ -e "$path" ] && command -v realpath >/dev/null 2>&1; then
    realpath "$path"
    return 0
  fi
  if [ -e "$path" ] && readlink -f "$path" >/dev/null 2>&1; then
    readlink -f "$path"
    return 0
  fi
  local dir
  dir="$(dirname "$path")"
  local base
  base="$(basename "$path")"
  if [ -d "$dir" ]; then
    (cd "$dir" && printf '%s/%s\n' "$(pwd -P)" "$base")
  else
    printf '%s\n' "$path"
  fi
}

same_canonical_path() {
  local left="$1"
  local right="$2"
  [ -n "$left" ] && [ -n "$right" ] && [ "$(canonical_path "$left")" = "$(canonical_path "$right")" ]
}

is_project_nix_bwrap() {
  local candidate="$1"
  local project_bwrap="${PI_ENV_NIX_PROJECT_BWRAP:-}"
  same_canonical_path "$candidate" "$project_bwrap"
}

is_ignored_nix_bwrap() {
  local candidate="$1"
  local ignored="${PI_ENV_NIX_IGNORED_BWRAP:-}"
  if [ -z "$candidate" ] || [ -z "$ignored" ]; then
    return 1
  fi
  if is_project_nix_bwrap "$candidate"; then
    return 1
  fi
  same_canonical_path "$candidate" "$ignored"
}

path_entry_count() {
  local needle="$1"
  local haystack="$2"
  local count=0
  local entry
  while IFS= read -r -d ':' entry; do
    if [ "$entry" = "$needle" ]; then
      count=$((count + 1))
    fi
  done < <(printf '%s:' "$haystack")
  printf '%s\n' "$count"
}

is_ignored_nix_path_bwrap() {
  local candidate="$1"
  if ! is_ignored_nix_bwrap "$candidate"; then
    return 1
  fi

  # A project flake may legitimately provide the same Nix-store pi-env-bwrap
  # path as the profile-installed command.  The preferred signal is the
  # PI_ENV_NIX_PROJECT_BWRAP marker exported by pi-env's devshell; keep the
  # PATH-count fallback for older test/devshell shims that prepend duplicate
  # entries rather than exporting the marker.
  local old_path="${PI_ENV_NIX_IGNORED_PATH:-}"
  local candidate_dir
  candidate_dir="$(dirname "$candidate")"
  local old_count
  old_count="$(path_entry_count "$candidate_dir" "$old_path")"
  local current_count
  current_count="$(path_entry_count "$candidate_dir" "${PATH:-}")"
  [ "$current_count" -le "$old_count" ]
}

exec_nix_runtime() {
  if [ "${PI_ENV_NIX_RUNTIME_READY:-0}" = "1" ]; then
    local ready_pi_bwrap="${PI_ENV_PI_ENV_BWRAP:-}"
    if is_ignored_nix_bwrap "$ready_pi_bwrap"; then
      ready_pi_bwrap=""
    fi
    if [ -z "$ready_pi_bwrap" ] && command -v pi-env-bwrap >/dev/null 2>&1; then
      ready_pi_bwrap="$(command -v pi-env-bwrap)"
      if is_ignored_nix_path_bwrap "$ready_pi_bwrap"; then
        ready_pi_bwrap=""
      fi
    fi
    if [ -z "$ready_pi_bwrap" ]; then
      echo "pi-env: runtime mode 'nix' entered nix develop, but project pi-env-bwrap was not found." >&2
      echo "pi-env: ensure the selected flake provides the pi-env runtime or pass a flake that does." >&2
      exit 127
    fi
    if [ "$shell_mode" = "1" ]; then
      exec "$ready_pi_bwrap" --shell -- "${args[@]}"
    elif [ "$raw" = "1" ]; then
      exec "$ready_pi_bwrap" -- "${args[@]}"
    fi
    exec_pi_bwrap_default "$ready_pi_bwrap"
  fi

  select_default_nix_flake

  if ! command -v nix >/dev/null 2>&1; then
    echo "pi-env: runtime mode 'nix' requires nix, but nix was not found on PATH." >&2
    echo "pi-env: install Nix, enter a pi-env devshell, or select --runtime host for unpinned host tools." >&2
    exit 127
  fi

  local nix_command=pi-env
  if [ "$shell_mode" = "1" ]; then
    nix_command=pi-env-shell
  fi
  local nix_args=(develop "$flake_ref" -c "$nix_command")
  if [ "$raw" = "1" ]; then
    nix_args+=(--raw --)
  fi
  PI_ENV_RUNTIME="$runtime_mode" \
    PI_ENV_NIX_RUNTIME_READY=1 \
    PI_ENV_NIX_IGNORED_BWRAP="${PI_ENV_PI_ENV_BWRAP:-}" \
    PI_ENV_NIX_IGNORED_PATH="${PATH:-}" \
    PI_ENV_NIX_PROJECT_BWRAP= \
    exec nix "${nix_args[@]}" "${args[@]}"
}

exec_auto_runtime() {
  local pi_bwrap="${PI_ENV_PI_ENV_BWRAP:-pi-env-bwrap}"
  if [ -n "${PI_ENV_PI_ENV_BWRAP:-}" ] || command -v "$pi_bwrap" >/dev/null 2>&1; then
    if [ "$shell_mode" = "1" ]; then
      exec "$pi_bwrap" --shell -- "${args[@]}"
    elif [ "$raw" = "1" ]; then
      exec "$pi_bwrap" -- "${args[@]}"
    fi
    exec_pi_bwrap_default "$pi_bwrap"
  fi
  exec_nix_runtime
}

case "$runtime_mode" in
  host) exec_host_runtime ;;
  nix) exec_nix_runtime ;;
  auto) exec_auto_runtime ;;
esac
