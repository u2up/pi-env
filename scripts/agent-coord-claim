#!/usr/bin/env bash
set -euo pipefail

if [ -n "${PI_ENV_COORD_LIB:-}" ]; then
  # shellcheck source=/dev/null
  . "$PI_ENV_COORD_LIB"
else
  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
  # shellcheck source=agent-coord-lib.sh
  . "$script_dir/agent-coord-lib.sh"
fi

usage() {
  cat <<'USAGE'
agent-coord-claim - claim a coordination item

Usage:
  agent-coord-claim [options] ITEM

Options:
  --coord-dir DIR   Coordination clone; default: PI_COORD_DIR or ./coordination
  --agent-id ID     Agent identity; default: PI_COORD_AGENT_ID or USER
  --role ROLE       Coordination role; default: PI_COORD_ROLE
  --no-pull         Do not pull/rebase before claiming
  --no-push         Commit but do not push after claiming
  --force           Allow claiming an item owned by another agent
  -h, --help        Show this help
USAGE
}

coord_dir_opt=""
agent_id="$(coord_default_agent)"
role="$(coord_default_role)"
pull_first=1
push_after=1
force=0
item_query=""

while [ "$#" -gt 0 ]; do
  case "$1" in
    --coord-dir)
      [ "$#" -ge 2 ] || coord_die "--coord-dir requires a value"
      coord_dir_opt="$2"
      shift 2
      ;;
    --agent-id)
      [ "$#" -ge 2 ] || coord_die "--agent-id requires a value"
      agent_id="$2"
      shift 2
      ;;
    --role)
      [ "$#" -ge 2 ] || coord_die "--role requires a value"
      role="$2"
      shift 2
      ;;
    --no-pull)
      pull_first=0
      shift
      ;;
    --no-push)
      push_after=0
      shift
      ;;
    --force)
      force=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      if [ -n "$item_query" ]; then
        coord_die "unexpected extra argument: $1"
      fi
      item_query="$1"
      shift
      ;;
  esac
done

[ -n "$item_query" ] || coord_die "item is required"
[ -n "$agent_id" ] || coord_die "agent id must not be empty"

coord_dir="$(coord_resolve_dir "$coord_dir_opt")"
cd "$coord_dir"

if [ "$pull_first" = "1" ]; then
  coord_pull_rebase
fi

item_path="$(coord_repo_path "$(coord_find_item "$item_query")")"
item_id="$(coord_item_value "$item_path" id || true)"
status="$(coord_item_value "$item_path" status || true)"
owner="$(coord_item_value "$item_path" owner || true)"
if [ -z "$item_id" ]; then
  item_id="$(basename "$item_path")"
  item_id="${item_id%.yaml}"
  item_id="${item_id%.yml}"
  item_id="${item_id%.md}"
fi

if [ "$status" = "closed" ]; then
  coord_die "cannot claim a closed item: $item_id"
fi

if [ -n "$owner" ] && [ "$owner" != "$agent_id" ] && [ "$force" != "1" ]; then
  coord_die "item is owned by $owner; use --force to override"
fi

now="$(coord_timestamp_iso)"
actor="$(coord_effective_actor "$agent_id" "$role")"
event_id="$(coord_next_event_id "$item_path")"
message_id="$(coord_message_id_for_event "$event_id")"

coord_set_item_values \
  "$item_path" \
  "status=claimed" \
  "owner=$agent_id" \
  "updated=$now"
coord_set_current_pointers "$item_path" "$event_id" "$message_id"
coord_append_item_event_message \
  "$item_path" \
  "$event_id" \
  "claimed" \
  "$now" \
  "$agent_id" \
  "$role" \
  "$message_id" \
  "Claimed."

git add "$item_path"
if coord_git_has_staged_changes; then
  message="Claim $item_id"
  coord_validate_subject "$message"
  coord_git_commit "$actor" -m "$message"
else
  coord_note "item was already claimed by $agent_id"
fi

if [ "$push_after" = "1" ]; then
  git push
fi

printf '%s\n' "$item_path"
