#!/usr/bin/env bash
set -euo pipefail

if [ -n "${PI_ENV_COORD_LIB:-}" ]; then
  # shellcheck source=/dev/null
  . "$PI_ENV_COORD_LIB"
else
  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
  # shellcheck source=agent-coord-lib.sh
  . "$script_dir/agent-coord-lib.sh"
fi

usage() {
  cat <<'USAGE'
agent-coord-clone - clone a coordination repository

Usage:
  agent-coord-clone [options] [remote]

Options:
  --root DIR       Bare remote parent; default: PI_COORD_ROOT or ~/agent-remotes
  --workspace ID   Coordination domain; default: PI_COORD_WORKSPACE or cwd name
  --dir DIR        Clone target; default: PI_COORD_DIR or coordination
  -h, --help       Show this help

When remote is omitted, the command clones:
  <root>/<workspace>-coordination.git
USAGE
}

root="$(coord_default_root)"
workspace="$(coord_default_workspace)"
coord_dir="$(coord_default_dir)"
remote=""

while [ "$#" -gt 0 ]; do
  case "$1" in
    --root)
      [ "$#" -ge 2 ] || coord_die "--root requires a value"
      root="$2"
      shift 2
      ;;
    --workspace)
      [ "$#" -ge 2 ] || coord_die "--workspace requires a value"
      workspace="$2"
      shift 2
      ;;
    --dir)
      [ "$#" -ge 2 ] || coord_die "--dir requires a value"
      coord_dir="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      if [ -n "$remote" ]; then
        coord_die "unexpected extra argument: $1"
      fi
      remote="$1"
      shift
      ;;
  esac
done

if [ -z "$remote" ]; then
  [ -n "$workspace" ] || coord_die "workspace must not be empty"
  root="$(coord_abs "$root")"
  remote="$(coord_remote_for "$root" "$workspace")"
fi

if [ -e "$coord_dir" ]; then
  if [ -d "$coord_dir/.git" ]; then
    coord_note "clone already exists: $coord_dir"
    cd "$coord_dir"
    coord_git_config_defaults
    exit 0
  fi
  coord_die "target exists and is not a Git clone: $coord_dir"
fi

git clone "$remote" "$coord_dir"
cd "$coord_dir"
coord_git_config_defaults
coord_note "cloned coordination repo: $(pwd -P)"
