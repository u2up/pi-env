#!/usr/bin/env bash
set -euo pipefail

if [ -n "${PI_ENV_COORD_LIB:-}" ]; then
  # shellcheck source=/dev/null
  . "$PI_ENV_COORD_LIB"
else
  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
  # shellcheck source=agent-coord-lib.sh
  . "$script_dir/agent-coord-lib.sh"
fi

usage() {
  cat <<'USAGE'
agent-coord-clone - clone a coordination repository

Usage:
  agent-coord-clone [options] [remote]

Options:
  --root DIR       Bare remote parent; default: PI_COORD_ROOT or .pi-env/agent-remotes
  --remote URL     Coordination remote URL; default: PI_COORD_REMOTE_URL
  --project ID     Coordination project; default: PI_COORD_PROJECT or cwd name
  --dir DIR        Clone target; default: PI_COORD_DIR or .pi-env/coordination
  -h, --help       Show this help

Remote precedence is explicit --remote or positional remote, then
PI_COORD_REMOTE_URL, then .pi-env-coordination.yaml coordination_remote,
then:
  <root>/<project>-coordination.git
USAGE
}

coord_set_or_add_origin_url() {
  local repo url
  repo="$1"
  url="$2"
  if git -C "$repo" remote get-url origin >/dev/null 2>&1; then
    git -C "$repo" remote set-url origin "$url"
  else
    git -C "$repo" remote add origin "$url"
  fi
}

root="$(coord_default_root)"
project="${PI_COORD_PROJECT:-}"
coord_dir="$(coord_default_dir)"
remote="${PI_COORD_REMOTE_URL:-}"
remote_set=0
remote_is_default_local=0
[ -n "$remote" ] && remote_set=1

while [ "$#" -gt 0 ]; do
  case "$1" in
    --root)
      [ "$#" -ge 2 ] || coord_die "--root requires a value"
      root="$2"
      shift 2
      ;;
    --remote)
      [ "$#" -ge 2 ] || coord_die "--remote requires a value"
      remote="$2"
      remote_set=1
      shift 2
      ;;
    --workspace)
      coord_die "--workspace has been removed; use --project"
      ;;
    --project)
      [ "$#" -ge 2 ] || coord_die "--project requires a value"
      project="$2"
      shift 2
      ;;
    --dir)
      [ "$#" -ge 2 ] || coord_die "--dir requires a value"
      coord_dir="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      if [ "$remote_set" = "1" ]; then
        coord_die "unexpected extra argument: $1"
      fi
      remote="$1"
      remote_set=1
      shift
      ;;
  esac
done

if [ -z "$remote" ]; then
  if remote="$(coord_resolve_coordination_remote "" || true)" && [ -n "$remote" ]; then
    remote_set=1
  fi
fi

if [ -z "$remote" ]; then
  if [ -z "$project" ]; then
    project="$(coord_default_workspace)"
  fi
  [ -n "$project" ] || coord_die "project must not be empty"
  root="$(coord_abs "$root")"
  remote="$(coord_remote_for "$root" "$project")"
  remote_is_default_local=1
fi

coord_ensure_operational_root_excluded "$coord_dir"

if [ -e "$coord_dir" ]; then
  if [ -d "$coord_dir/.git" ]; then
    coord_note "clone already exists: $coord_dir"
    if [ "$remote_is_default_local" = "1" ]; then
      coord_dir_abs="$(coord_abs "$coord_dir")"
      coord_set_or_add_origin_url \
        "$coord_dir_abs" \
        "$(coord_local_remote_url_for_clone "$coord_dir_abs" "$remote")"
    fi
    cd "$coord_dir"
    coord_git_config_defaults
    exit 0
  fi
  coord_die "target exists and is not a Git clone: $coord_dir"
fi

git clone "$remote" "$coord_dir"
coord_dir_abs="$(coord_abs "$coord_dir")"
if [ "$remote_is_default_local" = "1" ]; then
  coord_set_or_add_origin_url \
    "$coord_dir_abs" \
    "$(coord_local_remote_url_for_clone "$coord_dir_abs" "$remote")"
fi
cd "$coord_dir"
coord_git_config_defaults
coord_note "cloned coordination repo: $(pwd -P)"
