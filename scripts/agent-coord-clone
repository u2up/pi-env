#!/usr/bin/env bash
set -euo pipefail

if [ -n "${PI_ENV_COORD_LIB:-}" ]; then
  # shellcheck source=/dev/null
  . "$PI_ENV_COORD_LIB"
else
  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
  # shellcheck source=agent-coord-lib.sh
  . "$script_dir/agent-coord-lib.sh"
fi

usage() {
  cat <<'USAGE'
agent-coord-clone - clone a coordination repository

Usage:
  agent-coord-clone [options] [remote]

Options:
  --root DIR       Bare remote parent; default: PI_COORD_ROOT or project-visible agent-remotes
  --remote URL     Coordination remote URL; default: PI_COORD_REMOTE_URL
  --project ID     Coordination project; default: PI_COORD_PROJECT, PI_COORD_WORKSPACE, or cwd name
  --workspace ID   Legacy alias for --project when --project is omitted
  --dir DIR        Clone target; default: PI_COORD_DIR or coordination
  -h, --help       Show this help

Remote precedence is explicit --remote or positional remote, then
PI_COORD_REMOTE_URL, then:
  <root>/<project>-coordination.git
USAGE
}

root="$(coord_default_root)"
project="${PI_COORD_PROJECT:-}"
legacy_workspace=""
coord_dir="$(coord_default_dir)"
remote="${PI_COORD_REMOTE_URL:-}"
remote_set=0
[ -n "$remote" ] && remote_set=1

while [ "$#" -gt 0 ]; do
  case "$1" in
    --root)
      [ "$#" -ge 2 ] || coord_die "--root requires a value"
      root="$2"
      shift 2
      ;;
    --remote)
      [ "$#" -ge 2 ] || coord_die "--remote requires a value"
      remote="$2"
      remote_set=1
      shift 2
      ;;
    --workspace)
      [ "$#" -ge 2 ] || coord_die "--workspace requires a value"
      legacy_workspace="$2"
      shift 2
      ;;
    --project)
      [ "$#" -ge 2 ] || coord_die "--project requires a value"
      project="$2"
      shift 2
      ;;
    --dir)
      [ "$#" -ge 2 ] || coord_die "--dir requires a value"
      coord_dir="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      if [ "$remote_set" = "1" ]; then
        coord_die "unexpected extra argument: $1"
      fi
      remote="$1"
      remote_set=1
      shift
      ;;
  esac
done

if [ -z "$remote" ]; then
  if [ -z "$project" ]; then
    if [ -n "$legacy_workspace" ]; then
      project="$legacy_workspace"
    else
      project="$(coord_default_workspace)"
    fi
  fi
  [ -n "$project" ] || coord_die "project must not be empty"
  root="$(coord_abs "$root")"
  remote="$(coord_remote_for "$root" "$project")"
fi

if [ -e "$coord_dir" ]; then
  if [ -d "$coord_dir/.git" ]; then
    coord_note "clone already exists: $coord_dir"
    cd "$coord_dir"
    coord_git_config_defaults
    exit 0
  fi
  coord_die "target exists and is not a Git clone: $coord_dir"
fi

git clone "$remote" "$coord_dir"
cd "$coord_dir"
coord_git_config_defaults
coord_note "cloned coordination repo: $(pwd -P)"
