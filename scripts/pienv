#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
repo_root="$(cd "$script_dir/.." 2>/dev/null && pwd -P || printf '%s' "$script_dir")"

usage() {
  cat <<'USAGE'
pienv - pi-env command namespace

Usage:
  pienv [launcher options] [pi args...]
  pienv [launcher options] -- [pi args...]
  pienv run [launcher options] [pi args...]
  pienv [launcher options] --raw -- [pi args...]
  pienv raw -- [pi args...]
  pienv shell [launcher options] [shell args...]
  pienv sandbox [pi args...]
  pienv sandbox shell [shell args...]
  pienv coord <command> [args...]
  pienv roles serial [args...]
  pienv recipe flake-agent-shell
  pienv install [args...]
  pienv uninstall [args...]
  pienv completion bash
  pienv help [command...]

Commands:
  run                 Run pi-env (existing command: pi-env)
  raw                 Run pi-env with --raw (existing command: pi-env --raw)
  shell               Run a pi-env shell (existing command: pi-env-shell)
  sandbox             Run the sandbox helper (existing command: pi-env-bwrap)
  coord               Coordination helpers (existing commands: pi-env-coord-*)
  roles serial        Serial role orchestrator (existing command: pi-env-serial-roles)
  recipe              Print non-mutating integration recipes
  install             Non-Nix installer (existing command: pi-env-install-non-nix)
  uninstall           Non-Nix uninstaller (existing command: pi-env-uninstall)
  completion bash     Print Bash completion for pienv
  help                Show help for pienv commands

Launcher options for the default, run, shell, and pi-env --raw forms:
  --runtime host|nix|auto  Select host tools, Nix-backed runtime, or auto.
  --flake REF              Select the Nix flake used by --runtime nix|auto.
  --devshell NAME          Select the Nix devShell name for --runtime nix|auto.

Environment variables provide the same defaults: PI_ENV_RUNTIME, PI_ENV_FLAKE,
and PI_ENV_NIX_DEVSHELL. CLI options win over environment values. These
launcher options are passed to pi-env or pi-env-shell. For raw mode, put
launcher options before --raw (for example, 'pienv --runtime host --raw -- ...');
the 'pienv raw' namespace remains a thin 'pi-env --raw' dispatcher. Coordination,
recipe, install, uninstall, and sandbox commands have separate option sets.

Use 'pienv -- ...' to pass a first Pi argument that would otherwise be
parsed as a pienv subcommand.
USAGE
}

coord_help() {
  cat <<'USAGE'
pienv coord - coordination command namespace

Usage:
  pienv coord <command> [args...]
  pienv coord rules upgrade [args...]
  pienv coord requirements generate [args...]
  pienv coord requirements coverage [args...]

Commands:
  bootstrap              Existing command: pi-env-bootstrap-coordination
  init                   Existing command: pi-env-coord-init
  clone                  Existing command: pi-env-coord-clone
  status                 Existing command: pi-env-coord-status
  list                   Existing command: pi-env-coord-list
  show                   Existing command: pi-env-coord-cat
  new                    Existing command: pi-env-coord-new
  claim                  Existing command: pi-env-coord-claim
  done                   Existing command: pi-env-coord-done
  review                 Existing command: pi-env-coord-review
  verify                 Existing command: pi-env-coord-verify
  close                  Existing command: pi-env-coord-close
  pull                   Existing command: pi-env-coord-pull
  push                   Existing command: pi-env-coord-push
  lint                   Existing command: pi-env-coord-lint
  repo                   Existing command: pi-env-coord-repo
  rules upgrade          Existing command: pi-env-coord-upgrade-rules
  requirements generate  Existing command: pi-env-coord-generate-requirements
  requirements coverage  Existing command: pi-env-coord-generate-requirements-coverage

Use 'pienv help coord <command>' or 'pienv coord <command> --help' for
leaf command help.
USAGE
}

coord_rules_help() {
  cat <<'USAGE'
pienv coord rules - coordination rules commands

Usage:
  pienv coord rules upgrade [args...]

Commands:
  upgrade  Upgrade coordination rules (existing command: pi-env-coord-upgrade-rules)
USAGE
}

coord_requirements_help() {
  cat <<'USAGE'
pienv coord requirements - coordination requirements commands

Usage:
  pienv coord requirements generate [args...]
  pienv coord requirements coverage [args...]

Commands:
  generate  Generate requirements from designs (existing command: pi-env-coord-generate-requirements)
  coverage  Generate requirements coverage report (existing command: pi-env-coord-generate-requirements-coverage)
USAGE
}

roles_help() {
  cat <<'USAGE'
pienv roles - role orchestration commands

Usage:
  pienv roles serial [args...]

Commands:
  serial  Run serial role orchestration (existing command: pi-env-serial-roles)
USAGE
}

recipe_help() {
  cat <<'USAGE'
pienv recipe - copyable pi-env integration recipes

Usage:
  pienv recipe flake-agent-shell

Commands:
  flake-agent-shell  Print the canonical non-mutating flake .#agent shell recipe

Recipes only print guidance. They do not modify project files.
USAGE
}

flake_agent_shell_recipe() {
  cat <<'RECIPE'
# pienv recipe flake-agent-shell

Purpose: make `nix develop .#agent` the pi-env-aware agent entrypoint for
an existing flake without replacing project devShells, packages, FHS shells,
containers, or project-specific shell policy. Pi-env-integrated projects should
always expose devShells.<system>.agent; it can be a dedicated mkPiShell shell or
an alias when the default shell is already pi-env-aware. This command is
informational only and does not read, edit, or write project files.

1. Add the pi-env input next to existing inputs:

```nix
inputs = {
  # existing inputs...

  # Local checkout for active pi-env development:
  pi-env.url = "git+file:///home/me/src/pi-env";
  # Shared/pinned alternative:
  # pi-env.url = "github:u2up/pi-env";

  # Follow the project's pins when those inputs exist.
  pi-env.inputs.nixpkgs.follows = "nixpkgs";
  pi-env.inputs.flake-utils.follows = "flake-utils";
};
```

2. Include `pi-env` in the outputs argument set:

```nix
outputs = { self, nixpkgs, flake-utils, pi-env, ... }:
  # existing outputs...
```

3. Preserve existing devShells and choose one `agent` pattern.

Dedicated agent shell pattern:

```nix
let
  pkgs = import nixpkgs { inherit system; };
in {
  # If this flake already has devShells.${system}, keep that expression on
  # the left side of `//` instead of reading this output back through self.
  # For example, move existing shells into this attrset or replace it with
  # the flake's current devShells.${system} expression.
  devShells.${system} = {
    # default = pkgs.mkShell { ...existing project shell...; };
  } // {
    agent = pi-env.lib.mkPiShell {
      inherit pkgs;

      # Set to true, or omit because true is the default, when this project
      # uses pi-env-bootstrap-coordination or pi-env-coord-* helpers.
      includeCoordinationHelpers = false;

      extraPackages = with pkgs; [
        # Project-specific tools Pi should see inside Bubblewrap, for example:
        # gnumake
        # nodejs
        # python3
      ];

      shellHook = ''
        echo "Pi agent shell loaded. Use 'pienv' or 'pienv shell'."
      '';
    };
  };
}
```

Alias pattern when the default shell is already pi-env-aware:

```nix
let
  pkgs = import nixpkgs { inherit system; };
  existingDevShells = {
    default = pi-env.lib.mkPiShell {
      inherit pkgs;
      includeCoordinationHelpers = true;
      extraPackages = with pkgs; [ ];
    };
  };
in {
  devShells.${system} = existingDevShells // {
    # Keep `nix develop .#agent` stable without replacing the default shell.
    agent = existingDevShells.default;
  };
}
```

For flakes that already construct `devShells.${system}` with mapAttrs, an FHS
builder, flake-parts, devenv, or a container output, keep that structure and
append only the dedicated `// { agent = pi-env.lib.mkPiShell { ... }; }` merge
or alias `// { agent = existingDevShells.default; }` at the smallest safe point.
Do not create a project-native shell that only happens to be named `agent`; a
pi-env-aware shell must expose `pienv` and the pi-env runtime through
`pi-env.lib.mkPiShell` or equivalent pi-env packages.

Coordination variants:
- `includeCoordinationHelpers = true;` includes `pienv coord ...`,
  pi-env-bootstrap-coordination, pi-env-coord-*, and role orchestration helpers.
- `includeCoordinationHelpers = false;` keeps a smaller runtime shell when the
  project does not use Git-backed coordination.

After editing manually, run:

```bash
nix flake lock --update-input pi-env
nix develop .#agent
pienv --help
```
RECIPE
}

completion_help() {
  cat <<'USAGE'
pienv completion - shell completion commands

Usage:
  pienv completion bash

Commands:
  bash  Print a sourceable Bash completion script for pienv
USAGE
}

bash_completion() {
  cat <<'COMPLETION'
_pienv() {
  local cur prev words cword command_path option_words path_options launcher_options raw_marker_seen i
  COMPREPLY=()
  if declare -F _init_completion >/dev/null 2>&1; then
    _init_completion || return
  else
    cur="${COMP_WORDS[COMP_CWORD]}"
    prev="${COMP_WORDS[COMP_CWORD-1]}"
    words=("${COMP_WORDS[@]}")
    cword=$COMP_CWORD
  fi

  _pienv_comp_words() {
    compgen -W "$1" -- "$cur"
  }

  launcher_options="--runtime --runtime= --flake --flake= --devshell --devshell= --help -h"
  path_options="--coord-dir --coordination-dir --designs-dir --output -o --prefix --artifact-url --flake"

  raw_marker_seen=false
  for ((i = 1; i < cword; i++)); do
    if [ "${words[i]}" = "--raw" ]; then
      raw_marker_seen=true
      break
    fi
  done

  command_path=""
  case "${words[1]:-}" in
    coord)
      command_path="coord"
      case "${words[2]:-}" in
        rules) [ "${words[3]:-}" = "upgrade" ] && command_path="coord rules upgrade" ;;
        requirements)
          case "${words[3]:-}" in
            generate) command_path="coord requirements generate" ;;
            coverage) command_path="coord requirements coverage" ;;
          esac
          ;;
        bootstrap|init|clone|status|list|show|new|claim|done|review|verify|close|pull|push|lint|repo)
          command_path="coord ${words[2]}"
          ;;
      esac
      ;;
    run|raw|shell) command_path="${words[1]}" ;;
    sandbox) command_path="sandbox" ;;
    roles)
      command_path="roles"
      [ "${words[2]:-}" = "serial" ] && command_path="roles serial"
      ;;
    recipe)
      command_path="recipe"
      [ "${words[2]:-}" = "flake-agent-shell" ] && command_path="recipe flake-agent-shell"
      ;;
    install|uninstall|completion|help) command_path="${words[1]}" ;;
  esac

  if [ "$prev" = "--runtime" ]; then
    if ! $raw_marker_seen; then
      case "$command_path" in
        run|shell|"") COMPREPLY=( $(_pienv_comp_words "host nix auto") ) ;;
      esac
    fi
    return 0
  fi
  if [[ " $path_options " == *" $prev "* ]]; then
    compopt -o default 2>/dev/null || true
    return 0
  fi

  if [[ "$cur" == -* ]]; then
    case "$command_path" in
      coord\ status) option_words="--coord-dir --repo-id --porcelain --help -h" ;;
      coord\ list) option_words="--coord-dir --repo-id --all-repos --show-repo --category --show-category --group-by-category --help -h" ;;
      coord\ show) option_words="--coord-dir --path --help -h" ;;
      coord\ rules\ upgrade) option_words="--coord-dir --agent-id --role --preview --no-pull --push --help -h" ;;
      coord\ requirements\ generate) option_words="--project --coordination-dir --designs-dir --output -o --help -h" ;;
      coord\ requirements\ coverage) option_words="--project --coordination-dir --designs-dir --output -o --help -h" ;;
      coord\ claim|coord\ done|coord\ review|coord\ verify|coord\ close) option_words="--coord-dir --agent-id --role --result --message --no-pull --no-push --force --pass --fail --help -h" ;;
      coord\ bootstrap) option_words="--project-root --root --remote --project --project-key --repo-id --register-repo --implementation-remote --dir --agent-id --bare-only --print-only --dry-run --no-status --help -h" ;;
      coord\ pull|coord\ push|coord\ lint|coord\ repo|coord\ init|coord\ clone|coord\ new) option_words="--coord-dir --repo-id --help -h" ;;
      run|shell|"")
        if $raw_marker_seen; then
          option_words="--help -h"
        else
          option_words="$launcher_options"
        fi
        ;;
      raw) option_words="--help -h" ;;
      roles\ serial) option_words="--role --limit --coord-dir --help -h" ;;
      recipe\ flake-agent-shell) option_words="--help -h" ;;
      install) option_words="--prefix --check-deps --ref --repo --artifact-url --help -h" ;;
      uninstall) option_words="--prefix --help -h" ;;
      *) option_words="--help -h" ;;
    esac
    COMPREPLY=( $(_pienv_comp_words "$option_words") )
    return 0
  fi

  case "$cword" in
    1) COMPREPLY=( $(_pienv_comp_words "run raw shell sandbox coord roles recipe install uninstall help completion") ); return 0 ;;
  esac

  case "${words[1]:-}" in
    sandbox)
      [ "$cword" -eq 2 ] && COMPREPLY=( $(_pienv_comp_words "shell") )
      ;;
    coord)
      case "${words[2]:-}" in
        rules) [ "$cword" -eq 3 ] && COMPREPLY=( $(_pienv_comp_words "upgrade") ) ;;
        requirements) [ "$cword" -eq 3 ] && COMPREPLY=( $(_pienv_comp_words "generate coverage") ) ;;
        *) [ "$cword" -eq 2 ] && COMPREPLY=( $(_pienv_comp_words "bootstrap init clone status list show new claim done review verify close pull push lint repo rules requirements") ) ;;
      esac
      ;;
    roles)
      [ "$cword" -eq 2 ] && COMPREPLY=( $(_pienv_comp_words "serial") )
      ;;
    recipe)
      [ "$cword" -eq 2 ] && COMPREPLY=( $(_pienv_comp_words "flake-agent-shell") )
      ;;
    completion)
      [ "$cword" -eq 2 ] && COMPREPLY=( $(_pienv_comp_words "bash") )
      ;;
    help)
      case "${words[2]:-}" in
        "") [ "$cword" -eq 2 ] && COMPREPLY=( $(_pienv_comp_words "run raw shell sandbox coord roles recipe install uninstall completion") ) ;;
        coord)
          case "${words[3]:-}" in
            "") [ "$cword" -eq 3 ] && COMPREPLY=( $(_pienv_comp_words "bootstrap init clone status list show new claim done review verify close pull push lint repo rules requirements") ) ;;
            rules) [ "$cword" -eq 4 ] && COMPREPLY=( $(_pienv_comp_words "upgrade") ) ;;
            requirements) [ "$cword" -eq 4 ] && COMPREPLY=( $(_pienv_comp_words "generate coverage") ) ;;
          esac
          ;;
        roles) [ "$cword" -eq 3 ] && COMPREPLY=( $(_pienv_comp_words "serial") ) ;;
        recipe) [ "$cword" -eq 3 ] && COMPREPLY=( $(_pienv_comp_words "flake-agent-shell") ) ;;
        completion) [ "$cword" -eq 3 ] && COMPREPLY=( $(_pienv_comp_words "bash") ) ;;
      esac
      ;;
  esac
}
complete -F _pienv pienv
COMPLETION
}

resolve_command() {
  local name="$1"
  case "$name" in
    pi-env|pi-env-shell)
      if [ -x "$repo_root/$name" ]; then
        printf '%s\n' "$repo_root/$name"
        return 0
      fi
      ;;
  esac
  if [ -x "$script_dir/$name" ]; then
    printf '%s\n' "$script_dir/$name"
    return 0
  fi
  if command -v "$name" >/dev/null 2>&1; then
    command -v "$name"
    return 0
  fi
  echo "pienv: required command not found: $name" >&2
  return 127
}

exec_command() {
  local name="$1"
  shift
  local command_path
  command_path="$(resolve_command "$name")"
  exec "$command_path" "$@"
}

run_command_help() {
  local name="$1"
  shift
  local command_path
  command_path="$(resolve_command "$name")"
  "$command_path" --help
}

coord_leaf_command_name() {
  case "$1" in
    bootstrap) printf '%s\n' pi-env-bootstrap-coordination ;;
    init|clone|status|list|new|claim|done|review|verify|close|pull|push|lint|repo) printf 'pi-env-coord-%s\n' "$1" ;;
    show) printf '%s\n' pi-env-coord-cat ;;
    *) return 1 ;;
  esac
}

help_dispatch() {
  case "${1:-}" in
    "") usage ;;
    coord)
      shift
      case "${1:-}" in
        ""|-h|--help) coord_help ;;
        rules)
          shift
          case "${1:-}" in
            ""|-h|--help) coord_rules_help ;;
            upgrade) run_command_help pi-env-coord-upgrade-rules ;;
            *) unknown help coord rules "$1" ;;
          esac
          ;;
        requirements)
          shift
          case "${1:-}" in
            ""|-h|--help) coord_requirements_help ;;
            generate) run_command_help pi-env-coord-generate-requirements ;;
            coverage) run_command_help pi-env-coord-generate-requirements-coverage ;;
            *) unknown help coord requirements "$1" ;;
          esac
          ;;
        *)
          local leaf
          if leaf="$(coord_leaf_command_name "$1")"; then
            run_command_help "$leaf"
          else
            unknown help coord "$1"
          fi
          ;;
      esac
      ;;
    roles)
      shift
      case "${1:-}" in
        ""|-h|--help) roles_help ;;
        serial) run_command_help pi-env-serial-roles ;;
        *) unknown help roles "$1" ;;
      esac
      ;;
    recipe)
      shift
      case "${1:-}" in
        ""|-h|--help) recipe_help ;;
        flake-agent-shell) flake_agent_shell_recipe ;;
        *) unknown help recipe "$1" ;;
      esac
      ;;
    completion)
      shift
      case "${1:-}" in
        ""|-h|--help) completion_help ;;
        bash) completion_help ;;
        *) unknown help completion "$1" ;;
      esac
      ;;
    run) run_command_help pi-env ;;
    raw) run_command_help pi-env ;;
    shell) run_command_help pi-env-shell ;;
    sandbox) run_command_help pi-env-bwrap ;;
    install) run_command_help pi-env-install-non-nix ;;
    uninstall)
      if command -v pi-env-uninstall >/dev/null 2>&1; then
        run_command_help pi-env-uninstall
      else
        run_command_help pi-env-install-non-nix
      fi
      ;;
    *) unknown help "$1" ;;
  esac
}

unknown() {
  echo "pienv: unknown command: $*" >&2
  echo "Try 'pienv help'." >&2
  exit 2
}

if [ "$#" -eq 0 ]; then
  exec_command pi-env
fi

case "${1:-}" in
  -h|--help)
    usage
    exit 0
    ;;
  help)
    shift
    help_dispatch "$@"
    exit 0
    ;;
  --)
    shift
    exec_command pi-env "$@"
    ;;
  run)
    shift
    exec_command pi-env "$@"
    ;;
  raw)
    shift
    exec_command pi-env --raw "$@"
    ;;
  shell)
    shift
    exec_command pi-env-shell "$@"
    ;;
  sandbox)
    shift
    case "${1:-}" in
      -h|--help) run_command_help pi-env-bwrap; exit 0 ;;
      shell)
        shift
        exec_command pi-env-bwrap --shell "$@"
        ;;
    esac
    exec_command pi-env-bwrap "$@"
    ;;
  coord)
    shift
    case "${1:-}" in
      ""|-h|--help) coord_help; exit 0 ;;
      bootstrap) shift; exec_command pi-env-bootstrap-coordination "$@" ;;
      init|clone|status|list|new|claim|done|review|verify|close|pull|push|lint|repo)
        subcommand="$1"
        shift
        exec_command "pi-env-coord-$subcommand" "$@"
        ;;
      show) shift; exec_command pi-env-coord-cat "$@" ;;
      rules)
        shift
        case "${1:-}" in
          ""|-h|--help) coord_rules_help; exit 0 ;;
          upgrade) shift; exec_command pi-env-coord-upgrade-rules "$@" ;;
          *) unknown coord rules "${1:-}" ;;
        esac
        ;;
      requirements)
        shift
        case "${1:-}" in
          ""|-h|--help) coord_requirements_help; exit 0 ;;
          generate) shift; exec_command pi-env-coord-generate-requirements "$@" ;;
          coverage) shift; exec_command pi-env-coord-generate-requirements-coverage "$@" ;;
          *) unknown coord requirements "${1:-}" ;;
        esac
        ;;
      *) unknown coord "${1:-}" ;;
    esac
    ;;
  roles)
    shift
    case "${1:-}" in
      ""|-h|--help) roles_help; exit 0 ;;
      serial) shift; exec_command pi-env-serial-roles "$@" ;;
      *) unknown roles "${1:-}" ;;
    esac
    ;;
  recipe)
    shift
    case "${1:-}" in
      ""|-h|--help) recipe_help; exit 0 ;;
      flake-agent-shell)
        shift
        case "${1:-}" in
          "") flake_agent_shell_recipe; exit 0 ;;
          -h|--help) flake_agent_shell_recipe; exit 0 ;;
          *) unknown recipe flake-agent-shell "$@" ;;
        esac
        ;;
      *) unknown recipe "${1:-}" ;;
    esac
    ;;
  install)
    shift
    exec_command pi-env-install-non-nix "$@"
    ;;
  uninstall)
    shift
    if command -v pi-env-uninstall >/dev/null 2>&1; then
      exec_command pi-env-uninstall "$@"
    fi
    exec_command pi-env-install-non-nix --uninstall "$@"
    ;;
  completion)
    shift
    case "${1:-}" in
      ""|-h|--help) completion_help; exit 0 ;;
      bash)
        shift
        [ "$#" -eq 0 ] || unknown completion bash "$@"
        bash_completion
        ;;
      *) unknown completion "${1:-}" ;;
    esac
    ;;
  *)
    exec_command pi-env "$@"
    ;;
esac
