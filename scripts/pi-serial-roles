#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
if [ -n "${PI_ENV_COORD_LIB:-}" ]; then
  # shellcheck source=/dev/null
  . "$PI_ENV_COORD_LIB"
else
  # shellcheck source=agent-coord-lib.sh
  . "$script_dir/agent-coord-lib.sh"
fi

usage() {
  cat <<'USAGE'
pi-serial-roles - run serial developer/reviewer/tester Pi role jobs

Usage:
  pi-serial-roles [options]

Options:
  --project-root DIR      Project checkout to operate on; default: Git root or $PWD
  --coord-dir DIR         Coordination checkout; default: PI_COORD_DIR, .pi-env/coordination, or legacy ./coordination
                          relative to the project root
  --agent-id ID           Coordination agent identity; default: PI_COORD_AGENT_ID or USER
  --issue ID              Limit this run to one explicit coordination issue ID;
                          repeat this option for an ordered issue batch
  --sleep SECONDS         Idle poll sleep interval; default: 30
  --max-jobs N            Stop after running N Pi jobs
  --max-idle-polls N      Stop after N idle polls with no eligible work
  --once                  One bounded poll/job; same as --max-jobs 1 and
                          --max-idle-polls 1 when those are unset
  --dry-run               Pull and select, then print the claim/Pi command that
                          would run without claiming work or invoking Pi
  --ui interactive|json|none
                          Pi job UI/output mode; default: interactive.
                          interactive launches the normal TUI and requests
                          graceful exit after role_cycle_done, json emits a
                          structured event stream, and none runs a
                          non-interactive print job
  --lock-file PATH        Local lock path; default:
                          .pi-env/locks/pi-serial-roles.lock relative to
                          the project root
  --pi-env COMMAND        pi-env launcher; default: pi-env on PATH or this checkout
  --role-manager PATH     Role-manager package/path for raw Pi jobs; default:
                          PI_ENV_ROLE_MANAGER_PACKAGE or this checkout's role-manager
  --tools LIST            Tool allowlist for Pi; role_cycle_done is appended
                          when absent. Default:
                          read,bash,edit,write,grep,find,ls,role_cycle_done
  -h, --help              Show this help

Work priority:
  1. tester:   done issues with reviewed:true and verified:false
  2. reviewer: done issues with reviewed:false
  3. developer: open issues, claimed before Pi is invoked

Each job starts a fresh pi-env raw session and does not pass --continue.
USAGE
}

note() {
  printf 'pi-serial-roles: %s\n' "$*" >&2
}

die() {
  printf 'pi-serial-roles: %s\n' "$*" >&2
  exit 1
}

project_root_opt=""
coord_dir_opt=""
agent_id="$(coord_default_agent)"
sleep_seconds="30"
max_jobs=""
max_idle_polls=""
once=0
dry_run=0
ui_mode="interactive"
lock_file_opt=""
pi_env_cmd_opt=""
role_manager_opt=""
coord_helper_pi_dir=""
coord_helper_extra_path=""
coord_helper_host_ro_path=""
tools="${PI_BWRAP_DEFAULT_TOOLS:-read,bash,edit,write,grep,find,ls}"
role_cycle_done_tool="role_cycle_done"
requested_issue_ids=()

require_value() {
  [ -n "${2:-}" ] || die "$1 requires a value"
}

is_nonnegative_int() {
  case "$1" in
    ''|*[!0-9]*) return 1 ;;
    *) return 0 ;;
  esac
}

add_requested_issue_id() {
  local id existing
  id="$1"
  [ -n "$id" ] || die "--issue requires a non-empty ID"
  for existing in "${requested_issue_ids[@]}"; do
    if [ "$existing" = "$id" ]; then
      die "duplicate --issue ID: $id"
    fi
  done
  requested_issue_ids+=("$id")
}

explicit_issue_mode() {
  [ "${#requested_issue_ids[@]}" -gt 0 ]
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --project-root)
      require_value "$1" "${2:-}"
      project_root_opt="$2"
      shift 2
      ;;
    --coord-dir)
      require_value "$1" "${2:-}"
      coord_dir_opt="$2"
      shift 2
      ;;
    --agent-id)
      require_value "$1" "${2:-}"
      agent_id="$2"
      shift 2
      ;;
    --issue)
      require_value "$1" "${2:-}"
      add_requested_issue_id "$2"
      shift 2
      ;;
    --sleep|--poll-interval)
      require_value "$1" "${2:-}"
      sleep_seconds="$2"
      case "$sleep_seconds" in
        -*|'') die "--sleep must be a non-negative duration" ;;
      esac
      shift 2
      ;;
    --max-jobs)
      require_value "$1" "${2:-}"
      is_nonnegative_int "$2" || die "--max-jobs must be a non-negative integer"
      max_jobs="$2"
      shift 2
      ;;
    --max-idle-polls)
      require_value "$1" "${2:-}"
      is_nonnegative_int "$2" || die "--max-idle-polls must be a non-negative integer"
      max_idle_polls="$2"
      shift 2
      ;;
    --once)
      once=1
      shift
      ;;
    --dry-run)
      dry_run=1
      shift
      ;;
    --ui)
      require_value "$1" "${2:-}"
      case "$2" in
        interactive|json|none) ui_mode="$2" ;;
        *) die "--ui must be interactive, json, or none" ;;
      esac
      shift 2
      ;;
    --lock-file)
      require_value "$1" "${2:-}"
      lock_file_opt="$2"
      shift 2
      ;;
    --pi-env)
      require_value "$1" "${2:-}"
      pi_env_cmd_opt="$2"
      shift 2
      ;;
    --role-manager)
      require_value "$1" "${2:-}"
      role_manager_opt="$2"
      shift 2
      ;;
    --tools)
      require_value "$1" "${2:-}"
      tools="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      [ "$#" -eq 0 ] || die "unexpected positional arguments: $*"
      break
      ;;
    --*)
      die "unknown option: $1"
      ;;
    *)
      die "unexpected argument: $1"
      ;;
  esac
done

[ -n "$agent_id" ] || die "agent id must not be empty"
if [ "$once" = "1" ]; then
  [ -n "$max_jobs" ] || max_jobs=1
  [ -n "$max_idle_polls" ] || max_idle_polls=1
fi

resolve_project_root() {
  local root
  if [ -n "$project_root_opt" ]; then
    root="$(realpath -m "$project_root_opt")"
  else
    root="$(git rev-parse --show-toplevel 2>/dev/null || true)"
    if [ -z "$root" ]; then
      root="$(pwd -P)"
    fi
    root="$(realpath -m "$root")"
  fi
  [ -d "$root" ] || die "project root does not exist: $root"
  git -C "$root" rev-parse --is-inside-work-tree >/dev/null 2>&1 \
    || die "project root is not a Git working tree: $root"
  printf '%s\n' "$root"
}

resolve_relative_to_project() {
  local candidate project_root
  candidate="$1"
  project_root="$2"
  case "$candidate" in
    /*) realpath -m "$candidate" ;;
    *) realpath -m "$project_root/$candidate" ;;
  esac
}

resolve_coord_dir() {
  local project_root candidate coord_dir
  project_root="$1"
  if [ -n "$coord_dir_opt" ]; then
    candidate="$coord_dir_opt"
  elif [ -n "${PI_COORD_DIR:-}" ]; then
    candidate="$PI_COORD_DIR"
  elif [ -d "$project_root/.pi-env/coordination" ]; then
    candidate=".pi-env/coordination"
  elif [ -d "$project_root/coordination" ]; then
    candidate="coordination"
  else
    candidate=".pi-env/coordination"
  fi
  coord_dir="$(resolve_relative_to_project "$candidate" "$project_root")"
  [ -d "$coord_dir" ] || die "coordination dir not found: $coord_dir"
  [ -d "$coord_dir/.git" ] || die "not a coordination Git repo: $coord_dir"
  [ -f "$coord_dir/AGENTS.md" ] || die "coordination dir is missing AGENTS.md: $coord_dir"
  printf '%s\n' "$coord_dir"
}

resolve_command() {
  local command_name resolved
  command_name="$1"
  case "$command_name" in
    */*)
      resolved="$(realpath -m "$command_name")"
      [ -x "$resolved" ] || die "command is not executable: $resolved"
      printf '%s\n' "$resolved"
      ;;
    *)
      resolved="$(command -v "$command_name" 2>/dev/null || true)"
      [ -n "$resolved" ] || die "command not found on PATH: $command_name"
      printf '%s\n' "$resolved"
      ;;
  esac
}

resolve_pi_env_cmd() {
  if [ -n "$pi_env_cmd_opt" ]; then
    resolve_command "$pi_env_cmd_opt"
  elif command -v pi-env >/dev/null 2>&1; then
    command -v pi-env
  elif [ -x "$script_dir/../pi-env" ]; then
    realpath -m "$script_dir/../pi-env"
  else
    die "pi-env was not found; pass --pi-env or run inside the pi-env devshell"
  fi
}

resolve_role_manager() {
  local candidate
  if [ -n "$role_manager_opt" ]; then
    candidate="$role_manager_opt"
  elif [ -n "${PI_ENV_ROLE_MANAGER_PACKAGE:-}" ]; then
    candidate="$PI_ENV_ROLE_MANAGER_PACKAGE"
  elif [ -e "$script_dir/../role-manager" ]; then
    candidate="$script_dir/../role-manager"
  else
    die "role-manager package not found; set PI_ENV_ROLE_MANAGER_PACKAGE or pass --role-manager"
  fi
  candidate="$(realpath -m "$candidate")"
  [ -e "$candidate" ] || die "role-manager path does not exist: $candidate"
  printf '%s\n' "$candidate"
}

role_manager_arg_for_pi() {
  local candidate project_root
  candidate="$1"
  project_root="$2"
  case "$candidate" in
    /nix/store/*)
      printf '%s\n' "$candidate"
      ;;
    "$project_root")
      printf '/workspace\n'
      ;;
    "$project_root"/*)
      printf '/workspace%s\n' "${candidate#"$project_root"}"
      ;;
    *)
      # pi-bwrap rewrites and read-only binds external package paths passed
      # with -e/--package.  Allow installed non-Nix role-manager packages here
      # instead of rejecting them before pi-bwrap can make them available.
      printf '%s\n' "$candidate"
      ;;
  esac
}

coord_helper_dir_for_pi() {
  local candidate project_root
  candidate="$1"
  project_root="$2"
  case "$candidate" in
    /nix/store/*)
      printf '%s\n' "$candidate"
      ;;
    "$project_root")
      printf '/workspace\n'
      ;;
    "$project_root"/*)
      printf '/workspace%s\n' "${candidate#"$project_root"}"
      ;;
    *)
      # Installed non-Nix helper paths may be outside the project.  Do not
      # reject them during startup; host-runtime launches can bind or otherwise
      # expose the installed support directory as needed.
      printf '%s\n' "$candidate"
      ;;
  esac
}

coord_helper_prompt_cmd() {
  printf '%q' "$coord_helper_pi_dir/$1"
}

coord_helper() {
  local name
  name="$1"
  if [ -x "$script_dir/$name" ]; then
    printf '%s\n' "$script_dir/$name"
  else
    resolve_command "$name"
  fi
}

git_worktree_status() {
  local dir label
  dir="$1"
  label="$2"
  git -C "$dir" rev-parse --is-inside-work-tree >/dev/null 2>&1 \
    || die "$label is not a Git working tree: $dir"
  git -C "$dir" status --porcelain --untracked-files=normal
}

ensure_clean_git() {
  local dir label status
  dir="$1"
  label="$2"
  status="$(git_worktree_status "$dir" "$label")"
  if [ -n "$status" ]; then
    printf 'pi-serial-roles: unexpected dirty %s working tree: %s\n' "$label" "$dir" >&2
    printf '%s\n' "$status" >&2
    exit 1
  fi
}

is_clean_git() {
  local dir label status
  dir="$1"
  label="$2"
  status="$(git_worktree_status "$dir" "$label")"
  [ -z "$status" ]
}

install_lock_traps() {
  trap 'release_lock' EXIT
  trap 'release_lock; exit 130' INT
  trap 'release_lock; exit 143' TERM
}

acquire_lock() {
  local lock_file lock_dir old_pid
  lock_file="$1"
  lock_dir="$(dirname "$lock_file")"
  mkdir -p "$lock_dir"
  if ( set -o noclobber; printf '%s\n' "$$" >"$lock_file" ) 2>/dev/null; then
    install_lock_traps
    return
  fi

  old_pid="$(cat "$lock_file" 2>/dev/null || true)"
  if [ -n "$old_pid" ] && printf '%s' "$old_pid" | grep -Eq '^[0-9]+$' \
    && ! kill -0 "$old_pid" 2>/dev/null; then
    rm -f "$lock_file"
    if ( set -o noclobber; printf '%s\n' "$$" >"$lock_file" ) 2>/dev/null; then
      install_lock_traps
      return
    fi
  fi

  if [ -n "$old_pid" ]; then
    die "lock is already held at $lock_file by pid $old_pid"
  fi
  die "lock is already held at $lock_file"
}

release_lock() {
  if [ -n "${lock_file:-}" ] && [ -f "$lock_file" ]; then
    if [ "$(cat "$lock_file" 2>/dev/null || true)" = "$$" ]; then
      rm -f "$lock_file"
    fi
  fi
}

pull_coordination() {
  local pull_cmd
  ensure_clean_git "$coord_dir" "coordination"
  pull_cmd="$(coord_helper agent-coord-pull)"
  "$pull_cmd" --coord-dir "$coord_dir" >&2
  ensure_clean_git "$coord_dir" "coordination"
}

item_id_for_file() {
  local file item_id
  file="$1"
  item_id="$(coord_item_value "$file" id || true)"
  if [ -z "$item_id" ]; then
    item_id="$(basename "$file")"
    item_id="${item_id%.yaml}"
    item_id="${item_id%.yml}"
    item_id="${item_id%.md}"
  fi
  printf '%s\n' "$item_id"
}

status_lc_for_file() {
  coord_item_value "$1" status | tr '[:upper:]' '[:lower:]'
}

requested_issue_file_in_coord() {
  local requested_id file item_id matches match_count
  requested_id="$1"
  matches=""
  while IFS= read -r file; do
    [ -n "$file" ] || continue
    item_id="$(item_id_for_file "$file")"
    if [ "$item_id" = "$requested_id" ]; then
      matches="${matches}${file}"$'\n'
    fi
  done < <(coord_item_find_files)

  match_count="$(printf '%s' "$matches" | sed '/^$/d' | wc -l | tr -d ' ')"
  if [ "$match_count" = "0" ]; then
    die "requested issue not found: $requested_id"
  fi
  if [ "$match_count" != "1" ]; then
    printf 'pi-serial-roles: requested issue ID is ambiguous: %s\n%s' \
      "$requested_id" "$matches" >&2
    exit 1
  fi
  printf '%s' "$matches" | sed '/^$/d' | head -n 1
}

validate_requested_issues_in_coord() {
  local requested_id file raw_type file_type
  explicit_issue_mode || return 0
  for requested_id in "${requested_issue_ids[@]}"; do
    file="$(requested_issue_file_in_coord "$requested_id")"
    raw_type="$(coord_item_value "$file" type || true)"
    file_type="$(coord_item_type_canonical "$raw_type")"
    if [ "$file_type" != "issue" ]; then
      die "requested item is not an issue: $requested_id ($file has type ${raw_type:-unknown})"
    fi
  done
}

validate_requested_issues() {
  explicit_issue_mode || return 0
  ( cd "$coord_dir" && validate_requested_issues_in_coord )
}

issue_eligible_for_role() {
  local role file status owner
  role="$1"
  file="$2"
  status="$(status_lc_for_file "$file")"
  case "$role" in
    tester)
      [ "$status" = "done" ] || return 1
      coord_item_flag_true "$file" reviewed || return 1
      if coord_item_flag_true "$file" verified; then
        return 1
      fi
      return 0
      ;;
    reviewer)
      [ "$status" = "done" ] || return 1
      if coord_item_flag_true "$file" reviewed; then
        return 1
      fi
      return 0
      ;;
    developer)
      [ "$status" = "open" ] || return 1
      owner="$(coord_item_value "$file" owner || true)"
      [ -z "$owner" ] || [ "$owner" = "$agent_id" ]
      ;;
    *)
      die "unknown role: $role"
      ;;
  esac
}

select_next_requested_work_in_coord() {
  local role requested_id file item_id
  for role in tester reviewer developer; do
    for requested_id in "${requested_issue_ids[@]}"; do
      file="$(requested_issue_file_in_coord "$requested_id")"
      if issue_eligible_for_role "$role" "$file"; then
        item_id="$(item_id_for_file "$file")"
        printf '%s\t%s\t%s\n' "$role" "$item_id" "$file"
        return 0
      fi
    done
  done
  return 1
}

select_next_work_in_coord() {
  local file raw_type file_type status item_id owner

  if explicit_issue_mode; then
    select_next_requested_work_in_coord
    return $?
  fi

  while IFS= read -r file; do
    [ -n "$file" ] || continue
    raw_type="$(coord_item_value "$file" type || true)"
    file_type="$(coord_item_type_canonical "$raw_type")"
    [ "$file_type" = "issue" ] || continue
    status="$(status_lc_for_file "$file")"
    if [ "$status" = "done" ] \
      && coord_item_flag_true "$file" reviewed \
      && ! coord_item_flag_true "$file" verified; then
      item_id="$(item_id_for_file "$file")"
      printf 'tester\t%s\t%s\n' "$item_id" "$file"
      return 0
    fi
  done < <(coord_item_find_files)

  while IFS= read -r file; do
    [ -n "$file" ] || continue
    raw_type="$(coord_item_value "$file" type || true)"
    file_type="$(coord_item_type_canonical "$raw_type")"
    [ "$file_type" = "issue" ] || continue
    status="$(status_lc_for_file "$file")"
    if [ "$status" = "done" ] && ! coord_item_flag_true "$file" reviewed; then
      item_id="$(item_id_for_file "$file")"
      printf 'reviewer\t%s\t%s\n' "$item_id" "$file"
      return 0
    fi
  done < <(coord_item_find_files)

  while IFS= read -r file; do
    [ -n "$file" ] || continue
    raw_type="$(coord_item_value "$file" type || true)"
    file_type="$(coord_item_type_canonical "$raw_type")"
    [ "$file_type" = "issue" ] || continue
    status="$(status_lc_for_file "$file")"
    [ "$status" = "open" ] || continue
    owner="$(coord_item_value "$file" owner || true)"
    if [ -n "$owner" ] && [ "$owner" != "$agent_id" ]; then
      continue
    fi
    item_id="$(item_id_for_file "$file")"
    printf 'developer\t%s\t%s\n' "$item_id" "$file"
    return 0
  done < <(coord_item_find_files)

  return 1
}

select_next_work() {
  ( cd "$coord_dir" && select_next_work_in_coord )
}

role_prompt() {
  local role item ui goal helper_text session_text claim_helper done_helper review_helper verify_helper
  role="$1"
  item="$2"
  ui="$3"
  case "$role" in
    developer)
      claim_helper="$(coord_helper_prompt_cmd agent-coord-claim)"
      done_helper="$(coord_helper_prompt_cmd agent-coord-done)"
      goal="Implement coordination issue $item only."
      helper_text="The serial orchestrator selected this item and claims it before launch; if coordination shows it unclaimed, run $claim_helper for this item only before code changes. Commit project changes, mark the item done with $done_helper and structured implementation refs, then stop."
      ;;
    reviewer)
      review_helper="$(coord_helper_prompt_cmd agent-coord-review)"
      goal="Review coordination issue $item only."
      helper_text="Review the committed project state for this done item, then run $review_helper --pass or $review_helper --fail for this item and stop."
      ;;
    tester)
      verify_helper="$(coord_helper_prompt_cmd agent-coord-verify)"
      goal="Verify coordination issue $item only."
      helper_text="Run item-appropriate checks for this reviewed done item, then run $verify_helper --pass or $verify_helper --fail for this item and stop without closing other work."
      ;;
    *)
      die "unknown role: $role"
      ;;
  esac

  case "$ui" in
    none)
      session_text="This print-mode serial job starts a fresh non-interactive Pi session"
      ;;
    json)
      session_text="This headless serial job starts a fresh Pi JSON event stream session"
      ;;
    interactive)
      session_text="This watched auto-exit serial job starts a fresh Pi interactive session and requests shutdown after role_cycle_done"
      ;;
    *)
      die "unknown UI mode: $ui"
      ;;
  esac

  cat <<EOF_PROMPT
## Role cycle kickoff

Active role: $role
Goal: $goal

Run exactly one bounded cycle for the active role.

Serial coordination scope:

- Selected role: $role
- Selected item ID: $item
- Work only on this one coordination item; do not select other work.
- $helper_text

Operating constraints:

- Follow the active role instructions and its one-cycle workflow.
- Work only on the stated goal; do not start unrelated tasks.
- Project changes are allowed only when directly needed for the goal and
  permitted by the current repository instructions.
- Coordination changes are allowed only when directly needed for the goal and
  permitted by the current coordination rules.
- Use only context available in this session. $session_text and does not
  continue a prior conversation.
- Finish by calling \`role_cycle_done\` as the final action of the cycle.
  Treat that structured tool report as the role's expected final report.
- Populate every \`role_cycle_done\` field: \`summary\`, \`filesInspected\`,
  \`filesChanged\`, \`testsChecksRun\`, \`coordinationUpdates\`, and
  \`recommendedNextRole\`. Use empty arrays for list fields with no entries,
  and use \`none\` when there is no recommended next role.
- After calling \`role_cycle_done\`, stop. Do not emit another assistant
  response and do not begin a second role cycle.
EOF_PROMPT
}

tools_with_role_cycle_done() {
  local value
  value="$1"
  case ",$value," in
    *,"$role_cycle_done_tool",*) printf '%s\n' "$value" ;;
    ,) printf '%s\n' "$role_cycle_done_tool" ;;
    *) printf '%s,%s\n' "$value" "$role_cycle_done_tool" ;;
  esac
}

merged_pass_env() {
  local value
  value="${PI_BWRAP_PASS_ENV:-}"
  value="${value:+$value }PI_ACTIVE_ROLE PI_ROLE_MANAGER_ACTIVE_ROLE"
  if [ "$ui_mode" = "interactive" ]; then
    value="$value PI_ROLE_MANAGER_AUTO_SHUTDOWN_ON_DONE"
  fi
  printf '%s\n' "$value"
}

merged_extra_path() {
  local value helper_dir
  value="${PI_BWRAP_EXTRA_PATH:-}"
  helper_dir="${coord_helper_extra_path:-}"
  if [ -n "$helper_dir" ]; then
    case ":$value:" in
      *":$helper_dir:"*) ;;
      *) value="$helper_dir${value:+:$value}" ;;
    esac
  fi
  printf '%s\n' "$value"
}

merged_host_ro_paths() {
  local value helper_dir
  value="${PI_BWRAP_HOST_RO_PATHS:-}"
  helper_dir="${coord_helper_host_ro_path:-}"
  if [ -n "$helper_dir" ]; then
    case ":$value:" in
      *":$helper_dir:"*) ;;
      *) value="$helper_dir${value:+:$value}" ;;
    esac
  fi
  printf '%s\n' "$value"
}

shell_quote_command() {
  local first=1 arg
  for arg in "$@"; do
    if [ "$first" = "1" ]; then
      first=0
    else
      printf ' '
    fi
    printf '%q' "$arg"
  done
  printf '\n'
}

print_dry_run() {
  local role item prompt pass_env extra_path host_ro_paths pi_tools
  role="$1"
  item="$2"
  prompt="$3"
  pass_env="$(merged_pass_env)"
  extra_path="$(merged_extra_path)"
  host_ro_paths="$(merged_host_ro_paths)"
  pi_tools="$(tools_with_role_cycle_done "$tools")"

  printf 'selected role=%s item=%s\n' "$role" "$item"
  printf 'selected ui=%s\n' "$ui_mode"
  if [ "$role" = "developer" ]; then
    printf 'would-claim: '
    shell_quote_command \
      "$(coord_helper agent-coord-claim)" \
      --coord-dir "$coord_dir" \
      --agent-id "$agent_id" \
      --role developer \
      "$item"
  fi
  printf 'would-run: '
  case "$ui_mode" in
    none)
      shell_quote_command \
        env \
        "PI_ACTIVE_ROLE=$role" \
        "PI_ROLE_MANAGER_ACTIVE_ROLE=$role" \
        "PI_COORD_ROLE=$role" \
        "PI_COORD_AGENT_ID=$agent_id" \
        "PI_COORD_DIR=$coord_dir" \
        "PI_BWRAP_COORDINATION_DIR=$coord_dir" \
        "PI_BWRAP_PROJECT_ROOT=$project_root" \
        "PI_BWRAP_PASS_ENV=$pass_env" \
        "PI_BWRAP_EXTRA_PATH=$extra_path" \
        "PI_BWRAP_HOST_RO_PATHS=$host_ro_paths" \
        "$pi_env_cmd" \
        --raw -- \
        -e "$role_manager_pi_arg" \
        --tools "$pi_tools" \
        --print "$prompt"
      ;;
    json)
      shell_quote_command \
        env \
        "PI_ACTIVE_ROLE=$role" \
        "PI_ROLE_MANAGER_ACTIVE_ROLE=$role" \
        "PI_COORD_ROLE=$role" \
        "PI_COORD_AGENT_ID=$agent_id" \
        "PI_COORD_DIR=$coord_dir" \
        "PI_BWRAP_COORDINATION_DIR=$coord_dir" \
        "PI_BWRAP_PROJECT_ROOT=$project_root" \
        "PI_BWRAP_PASS_ENV=$pass_env" \
        "PI_BWRAP_EXTRA_PATH=$extra_path" \
        "PI_BWRAP_HOST_RO_PATHS=$host_ro_paths" \
        "$pi_env_cmd" \
        --raw -- \
        -e "$role_manager_pi_arg" \
        --tools "$pi_tools" \
        --mode json "$prompt"
      ;;
    interactive)
      shell_quote_command \
        env \
        "PI_ROLE_MANAGER_AUTO_SHUTDOWN_ON_DONE=1" \
        "PI_ACTIVE_ROLE=$role" \
        "PI_ROLE_MANAGER_ACTIVE_ROLE=$role" \
        "PI_COORD_ROLE=$role" \
        "PI_COORD_AGENT_ID=$agent_id" \
        "PI_COORD_DIR=$coord_dir" \
        "PI_BWRAP_COORDINATION_DIR=$coord_dir" \
        "PI_BWRAP_PROJECT_ROOT=$project_root" \
        "PI_BWRAP_PASS_ENV=$pass_env" \
        "PI_BWRAP_EXTRA_PATH=$extra_path" \
        "PI_BWRAP_HOST_RO_PATHS=$host_ro_paths" \
        "$pi_env_cmd" \
        --raw -- \
        -e "$role_manager_pi_arg" \
        --tools "$pi_tools" \
        "$prompt"
      ;;
    *)
      die "unknown UI mode: $ui_mode"
      ;;
  esac
}

claim_developer_item() {
  local item claim_cmd
  item="$1"
  claim_cmd="$(coord_helper agent-coord-claim)"
  "$claim_cmd" \
    --coord-dir "$coord_dir" \
    --agent-id "$agent_id" \
    --role developer \
    "$item" >&2
  ensure_clean_git "$coord_dir" "coordination"
}

run_pi_job() {
  local role item prompt pass_env extra_path host_ro_paths pi_tools
  role="$1"
  item="$2"
  prompt="$3"
  pass_env="$(merged_pass_env)"
  extra_path="$(merged_extra_path)"
  host_ro_paths="$(merged_host_ro_paths)"
  pi_tools="$(tools_with_role_cycle_done "$tools")"

  if [ "$role" = "developer" ]; then
    claim_developer_item "$item"
  fi

  ensure_clean_git "$project_root" "project"
  ensure_clean_git "$coord_dir" "coordination"

  note "launching $role job for $item with ui=$ui_mode"
  (
    cd "$project_root"
    case "$ui_mode" in
      none)
        env \
          "PI_ACTIVE_ROLE=$role" \
          "PI_ROLE_MANAGER_ACTIVE_ROLE=$role" \
          "PI_COORD_ROLE=$role" \
          "PI_COORD_AGENT_ID=$agent_id" \
          "PI_COORD_DIR=$coord_dir" \
          "PI_BWRAP_COORDINATION_DIR=$coord_dir" \
          "PI_BWRAP_PROJECT_ROOT=$project_root" \
          "PI_BWRAP_PASS_ENV=$pass_env" \
          "PI_BWRAP_EXTRA_PATH=$extra_path" \
          "PI_BWRAP_HOST_RO_PATHS=$host_ro_paths" \
          "$pi_env_cmd" \
          --raw -- \
          -e "$role_manager_pi_arg" \
          --tools "$pi_tools" \
          --print "$prompt"
        ;;
      json)
        env \
          "PI_ACTIVE_ROLE=$role" \
          "PI_ROLE_MANAGER_ACTIVE_ROLE=$role" \
          "PI_COORD_ROLE=$role" \
          "PI_COORD_AGENT_ID=$agent_id" \
          "PI_COORD_DIR=$coord_dir" \
          "PI_BWRAP_COORDINATION_DIR=$coord_dir" \
          "PI_BWRAP_PROJECT_ROOT=$project_root" \
          "PI_BWRAP_PASS_ENV=$pass_env" \
          "PI_BWRAP_EXTRA_PATH=$extra_path" \
          "PI_BWRAP_HOST_RO_PATHS=$host_ro_paths" \
          "$pi_env_cmd" \
          --raw -- \
          -e "$role_manager_pi_arg" \
          --tools "$pi_tools" \
          --mode json "$prompt"
        ;;
      interactive)
        env \
          "PI_ROLE_MANAGER_AUTO_SHUTDOWN_ON_DONE=1" \
          "PI_ACTIVE_ROLE=$role" \
          "PI_ROLE_MANAGER_ACTIVE_ROLE=$role" \
          "PI_COORD_ROLE=$role" \
          "PI_COORD_AGENT_ID=$agent_id" \
          "PI_COORD_DIR=$coord_dir" \
          "PI_BWRAP_COORDINATION_DIR=$coord_dir" \
          "PI_BWRAP_PROJECT_ROOT=$project_root" \
          "PI_BWRAP_PASS_ENV=$pass_env" \
          "PI_BWRAP_EXTRA_PATH=$extra_path" \
          "PI_BWRAP_HOST_RO_PATHS=$host_ro_paths" \
          "$pi_env_cmd" \
          --raw -- \
          -e "$role_manager_pi_arg" \
          --tools "$pi_tools" \
          "$prompt"
        ;;
      *)
        die "unknown UI mode: $ui_mode"
        ;;
    esac
  )
}

project_root="$(resolve_project_root)"
coord_dir="$(resolve_coord_dir "$project_root")"
pi_env_cmd="$(resolve_pi_env_cmd)"
role_manager_package="$(resolve_role_manager)"
role_manager_pi_arg="$(role_manager_arg_for_pi "$role_manager_package" "$project_root")"
coord_helper_pi_dir="$(coord_helper_dir_for_pi "$script_dir" "$project_root")"
case "$coord_helper_pi_dir" in
  /nix/store/*)
    coord_helper_extra_path="$coord_helper_pi_dir"
    coord_helper_host_ro_path=""
    ;;
  /workspace|/workspace/*)
    coord_helper_extra_path=""
    coord_helper_host_ro_path=""
    ;;
  *)
    coord_helper_extra_path=""
    coord_helper_host_ro_path="$script_dir"
    ;;
esac

if [ -n "$lock_file_opt" ]; then
  lock_file="$(resolve_relative_to_project "$lock_file_opt" "$project_root")"
else
  lock_file="$(realpath -m "$project_root/.pi-env/locks/pi-serial-roles.lock")"
fi

(
  cd "$project_root"
  coord_ensure_operational_root_excluded "$lock_file"
)
acquire_lock "$lock_file"

if [ "${max_jobs:-}" = "0" ]; then
  note "max job limit is 0; exiting"
  exit 0
fi

jobs_run=0
idle_polls=0

while :; do
  selection=""
  ensure_clean_git "$project_root" "project"
  if ! is_clean_git "$coord_dir" "coordination"; then
    idle_polls=$((idle_polls + 1))
    if [ "$dry_run" = "1" ]; then
      printf 'selected role=none item=none\n'
      exit 0
    fi
    if [ -n "$max_idle_polls" ] && [ "$idle_polls" -ge "$max_idle_polls" ]; then
      note "idle poll limit reached ($idle_polls); exiting"
      exit 0
    fi
    note "coordination repo busy; sleeping ${sleep_seconds}s before polling again"
    sleep "$sleep_seconds"
    continue
  fi
  pull_coordination
  validate_requested_issues

  if selection="$(select_next_work)"; then
    IFS=$'\t' read -r role item _path <<<"$selection"
    idle_polls=0
    prompt="$(role_prompt "$role" "$item" "$ui_mode")"
    if [ "$dry_run" = "1" ]; then
      print_dry_run "$role" "$item" "$prompt"
      exit 0
    fi

    run_pi_job "$role" "$item" "$prompt" || die "$role job failed for $item"
    ensure_clean_git "$project_root" "project"
    ensure_clean_git "$coord_dir" "coordination"

    jobs_run=$((jobs_run + 1))
    if [ -n "$max_jobs" ] && [ "$jobs_run" -ge "$max_jobs" ]; then
      note "max job limit reached ($jobs_run); exiting"
      exit 0
    fi
  else
    idle_polls=$((idle_polls + 1))
    if [ "$dry_run" = "1" ]; then
      printf 'selected role=none item=none\n'
      exit 0
    fi
    if explicit_issue_mode; then
      note "requested issue batch has no eligible work; exiting"
      exit 0
    fi
    if [ -n "$max_idle_polls" ] && [ "$idle_polls" -ge "$max_idle_polls" ]; then
      note "idle poll limit reached ($idle_polls); exiting"
      exit 0
    fi
    note "no eligible issue; sleeping ${sleep_seconds}s before polling again"
    sleep "$sleep_seconds"
  fi
done
