#!/usr/bin/env bash
set -euo pipefail

if [ -n "${PI_ENV_COORD_LIB:-}" ]; then
  # shellcheck source=/dev/null
  . "$PI_ENV_COORD_LIB"
else
  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
  # shellcheck source=agent-coord-lib.sh
  . "$script_dir/agent-coord-lib.sh"
fi

usage() {
  cat <<'USAGE'
agent-coord-done - mark developer work done pending review/verification

Usage:
  agent-coord-done [options] ITEM

Options:
  --coord-dir DIR             Coordination clone; default: PI_ENV_COORD_DIR or .pi-env/coordination
  --agent-id ID               Agent identity; default: PI_ENV_COORD_AGENT_ID or USER
  --role ROLE                 Coordination role; default: PI_ENV_COORD_ROLE
  --result TEXT               Result/message text; default: Done.
  --repo-id ID                Implementation repository id; default: PI_ENV_COORD_REPO_ID,
                               .pi-env-coordination.yaml, or git remote inference
  --implementation-ref REF    Implementation ref in repo:branch@full-commit form;
                               may be repeated
  --no-pull                   Do not pull/rebase before marking done
  --no-push                   Commit but do not push after marking done
  --force                     Allow marking an item owned by another agent done
  -h, --help                  Show this help
USAGE
}

coord_dir_opt=""
agent_id="$(coord_default_agent)"
role="$(coord_default_role)"
result="Done."
pull_first=1
push_after=1
force=0
item_query=""
repo_id_opt=""
implementation_refs=()

while [ "$#" -gt 0 ]; do
  case "$1" in
    --coord-dir)
      [ "$#" -ge 2 ] || coord_die "--coord-dir requires a value"
      coord_dir_opt="$2"
      shift 2
      ;;
    --agent-id)
      [ "$#" -ge 2 ] || coord_die "--agent-id requires a value"
      agent_id="$2"
      shift 2
      ;;
    --role)
      [ "$#" -ge 2 ] || coord_die "--role requires a value"
      role="$2"
      shift 2
      ;;
    --result)
      [ "$#" -ge 2 ] || coord_die "--result requires a value"
      result="$2"
      shift 2
      ;;
    --repo-id)
      [ "$#" -ge 2 ] || coord_die "--repo-id requires a value"
      repo_id_opt="$2"
      shift 2
      ;;
    --implementation-ref)
      [ "$#" -ge 2 ] || coord_die "--implementation-ref requires a value"
      implementation_refs+=("$2")
      shift 2
      ;;
    --no-pull)
      pull_first=0
      shift
      ;;
    --no-push)
      push_after=0
      shift
      ;;
    --force)
      force=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      if [ -n "$item_query" ]; then
        coord_die "unexpected extra argument: $1"
      fi
      item_query="$1"
      shift
      ;;
  esac
done

[ -n "$item_query" ] || coord_die "item is required"
[ -n "$agent_id" ] || coord_die "agent id must not be empty"

project_dir="$(coord_project_root)"
coord_dir="$(coord_resolve_dir "$coord_dir_opt")"
cd "$coord_dir"

if [ "$pull_first" = "1" ]; then
  coord_pull_rebase
fi

item_path="$(coord_repo_path "$(coord_find_item "$item_query")")"
item_id="$(coord_item_value "$item_path" id || true)"
status="$(coord_item_value "$item_path" status || true)"
owner="$(coord_item_value "$item_path" owner || true)"
if [ -z "$item_id" ]; then
  item_id="$(basename "$item_path")"
  item_id="${item_id%.yaml}"
  item_id="${item_id%.yml}"
  item_id="${item_id%.md}"
fi

if [ "$status" = "closed" ]; then
  coord_die "cannot mark a closed item done: $item_id"
fi

if [ -n "$owner" ] && [ "$owner" != "$agent_id" ] && [ "$force" != "1" ]; then
  coord_die "item is owned by $owner; use --force to mark it done"
fi

for i in "${!implementation_refs[@]}"; do
  ref="${implementation_refs[$i]}"
  [ -n "$ref" ] || continue
  repo_part="${ref%%:*}"
  if [ -n "$repo_part" ] && [ "$repo_part" != "$ref" ]; then
    canonical_repo_part="$(coord_registry_canonical_repo_id "$repo_part" "$coord_dir")"
    if [ "$canonical_repo_part" != "$repo_part" ]; then
      implementation_refs[$i]="$canonical_repo_part:${ref#*:}"
    fi
  fi
  coord_write_implementation_ref_yaml "" "${implementation_refs[$i]}" >/dev/null
done

if [ ${#implementation_refs[@]} -eq 0 ] \
  && { [ -n "$repo_id_opt${PI_ENV_COORD_REPO_ID:-}" ] \
    || coord_impl_config_exists "$project_dir" \
    || git -C "$project_dir" remote get-url origin >/dev/null 2>&1; }; then
  resolved_repo_id="$(cd "$project_dir" && coord_resolve_repo_id "$repo_id_opt" "$coord_dir")"
  project_branch="$(git -C "$project_dir" rev-parse --abbrev-ref HEAD 2>/dev/null || true)"
  project_commit="$(git -C "$project_dir" rev-parse HEAD 2>/dev/null || true)"
  if [ -n "$project_branch" ] && [ "$project_branch" != "HEAD" ] && [[ "$project_commit" =~ ^[0-9A-Fa-f]{40}$ ]]; then
    implementation_refs+=("$resolved_repo_id:$project_branch@$project_commit")
  else
    coord_note "resolved repo id: $resolved_repo_id"
  fi
fi

item_path="$(coord_move_issue_item_to_status "$item_path" done)"

now="$(coord_timestamp_iso)"
actor="$(coord_effective_actor "$agent_id" "$role")"
event_id="$(coord_next_event_id "$item_path")"
message_id="$(coord_message_id_for_event "$event_id")"

coord_set_item_values \
  "$item_path" \
  "status=done" \
  "owner=$agent_id" \
  "updated=$now" \
  "done=$now" \
  "closed=null" \
  "reviewed=false" \
  "verified=false"
coord_set_current_pointers "$item_path" "$event_id" "$message_id"
coord_append_item_event_message \
  "$item_path" \
  "$event_id" \
  "done" \
  "$now" \
  "$agent_id" \
  "$role" \
  "$message_id" \
  "$result" \
  "${implementation_refs[@]}"

git add "$item_path"
if coord_git_has_staged_changes; then
  message="Mark $item_id done"
  coord_validate_subject "$message"
  coord_git_commit "$actor" -m "$message"
else
  coord_note "item was already done: $item_id"
fi

if [ "$push_after" = "1" ]; then
  git push
fi

printf '%s\n' "$item_path"
