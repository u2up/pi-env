#!/usr/bin/env bash
set -euo pipefail

if [ -n "${PI_ENV_COORD_LIB:-}" ]; then
  # shellcheck source=/dev/null
  . "$PI_ENV_COORD_LIB"
else
  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
  # shellcheck source=agent-coord-lib.sh
  . "$script_dir/agent-coord-lib.sh"
fi

usage() {
  cat <<'USAGE'
agent-coord-init - create and scaffold a coordination repository

Usage:
  agent-coord-init [options]

Options:
  --root DIR        Bare remote parent; default: PI_COORD_ROOT or .pi-env/agent-remotes
  --remote REMOTE   Coordination Git remote URL or local bare path; default: PI_COORD_REMOTE
  --project ID      Coordination project; default: PI_COORD_PROJECT or cwd name
  --project-key KEY Project item ID prefix; default: derived project
  --repo-id ID      Initial implementation repo id; default: PI_COORD_REPO_ID,
                   .pi-env-coordination.yaml repo_id, git remote, or project
  --dir DIR         Working clone dir; default: PI_COORD_DIR or .pi-env/coordination
  --agent-id ID     Agent identity; default: PI_COORD_AGENT_ID or USER
  --role ROLE       Coordination role; default: PI_COORD_ROLE
  --bare-only       Only create the bare remote
  -h, --help        Show this help

Remote precedence is explicit --remote, then PI_COORD_REMOTE,
then PI_COORD_REMOTE_URL, then .pi-env-coordination.yaml coordination_remote,
then:
  <root>/<project>-coordination.git
USAGE
}

root="$(coord_default_root)"
remote_url="$(coord_env_coordination_remote 2>/dev/null || true)"
coord_dir="$(coord_default_dir)"
agent_id="$(coord_default_agent)"
role="$(coord_default_role)"
project_key="${PI_COORD_PROJECT:-}"
project_id_key="${PI_COORD_PROJECT_KEY:-}"
repo_id_arg="${PI_COORD_REPO_ID:-}"
bare_only=0

while [ "$#" -gt 0 ]; do
  case "$1" in
    --root)
      [ "$#" -ge 2 ] || coord_die "--root requires a value"
      root="$2"
      shift 2
      ;;
    --remote)
      [ "$#" -ge 2 ] || coord_die "--remote requires a value"
      remote_url="$2"
      shift 2
      ;;
    --workspace)
      coord_die "--workspace has been removed; use --project"
      ;;
    --dir)
      [ "$#" -ge 2 ] || coord_die "--dir requires a value"
      coord_dir="$2"
      shift 2
      ;;
    --agent-id)
      [ "$#" -ge 2 ] || coord_die "--agent-id requires a value"
      agent_id="$2"
      shift 2
      ;;
    --role)
      [ "$#" -ge 2 ] || coord_die "--role requires a value"
      role="$2"
      shift 2
      ;;
    --project)
      [ "$#" -ge 2 ] || coord_die "--project requires a value"
      project_key="$2"
      shift 2
      ;;
    --project-key)
      [ "$#" -ge 2 ] || coord_die "--project-key requires a value"
      project_id_key="$2"
      shift 2
      ;;
    --repo-id)
      [ "$#" -ge 2 ] || coord_die "--repo-id requires a value"
      repo_id_arg="$2"
      shift 2
      ;;
    --bare-only)
      bare_only=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      coord_die "unknown argument: $1"
      ;;
  esac
done

if [ -z "$remote_url" ]; then
  remote_url="$(coord_resolve_coordination_remote "" || true)"
fi

if [ -z "$project_key" ]; then
  project_key="$(coord_default_workspace)"
fi
[ -n "$project_key" ] || coord_die "project must not be empty"
[ -n "$agent_id" ] || coord_die "agent id must not be empty"

remote_git_dir=""
if [ -n "$remote_url" ]; then
  remote="$remote_url"
  if remote_local_path="$(coord_remote_local_path "$remote" 2>/dev/null)"; then
    case "$remote_local_path" in
      /*) remote_git_dir="$(coord_abs "$remote_local_path")" ;;
      *) remote_git_dir="$(coord_abs "$(coord_project_root)/$remote_local_path")" ;;
    esac
    remote="$remote_git_dir"
    coord_ensure_operational_root_excluded "$remote_git_dir"

    if [ -e "$remote_git_dir" ] && [ ! -d "$remote_git_dir/objects" ]; then
      coord_die "remote path exists but is not a bare Git repo: $remote_git_dir"
    fi

    if [ ! -d "$remote_git_dir" ]; then
      mkdir -p "$(dirname "$remote_git_dir")"
      git init --bare --initial-branch=main "$remote_git_dir" >/dev/null 2>&1 \
        || git init --bare "$remote_git_dir" >/dev/null
      coord_note "created bare remote: $remote_git_dir"
    else
      coord_note "bare remote already exists: $remote_git_dir"
    fi
  else
    coord_note "using configured coordination remote: $remote"
  fi
else
  root="$(coord_abs "$root")"
  remote="$(coord_remote_for "$root" "$project_key")"
  coord_ensure_operational_root_excluded "$root"
  mkdir -p "$root"

  if [ -e "$remote" ] && [ ! -d "$remote/objects" ]; then
    coord_die "remote path exists but is not a bare Git repo: $remote"
  fi

  if [ ! -d "$remote" ]; then
    git init --bare --initial-branch=main "$remote" >/dev/null 2>&1 \
      || git init --bare "$remote" >/dev/null
    coord_note "created bare remote: $remote"
  else
    coord_note "bare remote already exists: $remote"
  fi
  remote_git_dir="$remote"
fi

if [ "$bare_only" = "1" ]; then
  exit 0
fi

initial_repo_source=""
initial_repo_id="$repo_id_arg"
if [ -n "$initial_repo_id" ]; then
  initial_repo_source="--repo-id or PI_COORD_REPO_ID"
else
  initial_repo_id="$(coord_impl_config_value repo_id || true)"
  if [ -n "$initial_repo_id" ]; then
    initial_repo_source="$(coord_impl_config_source || true)"
    [ -n "$initial_repo_source" ] || initial_repo_source="$(coord_impl_config_filename)"
  else
    initial_repo_id="$(coord_infer_repo_id_from_remote 2>/dev/null || true)"
    if [ -n "$initial_repo_id" ]; then
      initial_repo_source="git remote origin"
    else
      initial_repo_id="$(coord_sanitize_path_part "$project_key")"
      initial_repo_source="project"
    fi
  fi
fi
[ -n "$initial_repo_id" ] || coord_die "initial repo id must not be empty"
coord_repo_id_is_valid "$initial_repo_id" \
  || coord_die "invalid initial repo id '$initial_repo_id' from $initial_repo_source; use --repo-id with lowercase letters, digits, dots, underscores, and hyphens"

coord_ensure_operational_root_excluded "$coord_dir"

if [ -e "$coord_dir" ]; then
  if [ -d "$coord_dir" ] && [ -z "$(find "$coord_dir" -mindepth 1 -maxdepth 1 -print -quit)" ]; then
    rmdir "$coord_dir"
  else
    coord_die "working clone already exists: $coord_dir"
  fi
fi

git clone "$remote" "$coord_dir" >/dev/null 2>&1 || {
  rm -rf "$coord_dir"
  coord_die "failed to clone remote: $remote"
}

coord_dir_abs="$(coord_abs "$coord_dir")"
if [ -n "$remote_git_dir" ]; then
  git -C "$coord_dir_abs" remote set-url origin "$(coord_local_remote_url_for_clone "$coord_dir_abs" "$remote_git_dir")"
fi

cd "$coord_dir"
coord_git_config_defaults

if coord_git_has_head; then
  coord_note "clone already has commits; no scaffold was written"
  exit 0
fi

git checkout -B main >/dev/null 2>&1

project_dir="$(coord_sanitize_path_part "$project_key")"
agent_file="$(coord_sanitize_path_part "$agent_id")"
[ -n "$project_dir" ] || project_dir="project"
[ -n "$agent_file" ] || agent_file="agent"

created="$(coord_timestamp_iso)"
if [ -z "$project_id_key" ]; then
  project_id_key="$project_key"
fi
project_item_key="$(coord_project_id_prefix "$project_id_key")"

mkdir -p \
  docs \
  ".pi/skills/agent-coordination" \
  "repos/$initial_repo_id/issues/open" \
  "repos/$initial_repo_id/issues/blocked" \
  "repos/$initial_repo_id/issues/done" \
  "repos/$initial_repo_id/issues/closed" \
  requirements \
  todos \
  decisions \
  notes \
  agents

coord_install_template AGENTS.md AGENTS.md
coord_install_template SYNC_PROTOCOL.md docs/SYNC_PROTOCOL.md
coord_install_template ITEM_FORMAT.md docs/ITEM_FORMAT.md
coord_install_template SKILL.md .pi/skills/agent-coordination/SKILL.md

cat >README.md <<EOF_README
# $project_dir coordination

This repository stores Git-backed agent coordination state for the
$project_dir project.

Use normal Git pull, commit, and push operations to synchronize state.
Read AGENTS.md and docs/SYNC_PROTOCOL.md before changing shared items.

Issue state group names are developer-centric: \`open\` means developer work
is needed, \`blocked\` means developer work cannot proceed, \`done\` means the
developer believes implementation is complete, and \`closed\` means final
accepted after review and verification.

New issue items are stored under \`repos/<repo_id>/issues/<state>\`.
New item IDs use \`<KEY>-<TYPE>-<YYYYMMDD-HHMMSS>-<NNN>\`, with \`NNN\`
starting at \`001\` for each timestamp. Testable items are linked to project
repo scripts by matching item and test filename stems.

Declare generated domain-wide output files that this implementation repository
commits in its \`repos/<repo_id>/REPO.md\` manifest under
\`domain_generated_files\`.
EOF_README

initial_item_key="$(coord_project_id_prefix "$initial_repo_id")"
cat >"repos/$initial_repo_id/REPO.md" <<EOF_REPO
---
repo_id: $initial_repo_id
status: active
item_key: $initial_item_key
project: $initial_repo_id
created: $created
updated: $created
aliases: []
remotes: []
domain_generated_files: []
---

# $initial_repo_id

- Domain generated files: set \`domain_generated_files\` in this file when
  this implementation repo commits generated domain outputs.
EOF_REPO

cat >PROJECT.md <<EOF_PROJECT
---
project: $project_dir
item_key: $project_item_key
created: $created
---

# Project: $project_dir

- Project item key: $project_item_key
- Source name: $project_key
- Bare remote: $remote
EOF_PROJECT

cat >"agents/$agent_file.md" <<EOF_AGENT
# $agent_id

- Agent ID: $agent_id
- Created: $created

## Notes

EOF_AGENT

find repos requirements todos decisions notes agents -type d -empty -exec sh -c 'touch "$1/.gitkeep"' sh {} \;

actor="$(coord_effective_actor "$agent_id" "$role")"
if coord_commit_all_if_changed "Initialize coordination repository" "$actor"; then
  git push -u origin main >/dev/null
  if [ -n "$remote_git_dir" ] && [ -d "$remote_git_dir/objects" ]; then
    git --git-dir="$remote_git_dir" symbolic-ref HEAD refs/heads/main
  fi
  coord_note "initialized coordination clone: $(pwd -P)"
else
  coord_note "no changes to commit"
fi
