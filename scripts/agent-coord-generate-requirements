#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
agent-coord-generate-requirements - render REQUIREMENTS.md from coordination items

Usage:
  agent-coord-generate-requirements [--project NAME] [--coordination-dir DIR] [--output PATH]
  agent-coord-generate-requirements --help

Renders active requirement items from the coordination repository's root
requirements directory as a deterministic Markdown requirements document.
Requirement items keep coordination item-ID filenames; the public requirement
key is read from requirement_key metadata.
USAGE
}

project="${PI_COORD_PROJECT:-pi-env}"
coord_dir="${PI_COORD_DIR:-}"
output=""

while [ "$#" -gt 0 ]; do
  case "$1" in
    --project)
      [ "$#" -ge 2 ] || { echo "missing value for --project" >&2; exit 2; }
      project="$2"
      shift 2
      ;;
    --coordination-dir|--coord-dir)
      [ "$#" -ge 2 ] || { echo "missing value for $1" >&2; exit 2; }
      coord_dir="$2"
      shift 2
      ;;
    --output|-o)
      [ "$#" -ge 2 ] || { echo "missing value for --output" >&2; exit 2; }
      output="$2"
      shift 2
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      echo "unknown argument: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

if [ -z "$coord_dir" ]; then
  if [ -d ".pi-env/coordination" ]; then
    coord_dir=".pi-env/coordination"
  elif [ -d "coordination" ]; then
    coord_dir="coordination"
  else
    coord_dir=".pi-env/coordination"
  fi
fi

requirements_dirs=()
if [ -d "$coord_dir/requirements" ]; then
  requirements_dirs+=("$coord_dir/requirements")
fi
if [ -d "$coord_dir/projects/$project/requirements" ]; then
  requirements_dirs+=("$coord_dir/projects/$project/requirements")
fi
if [ "${#requirements_dirs[@]}" -eq 0 ]; then
  echo "requirements directory not found: $coord_dir/requirements or $coord_dir/projects/$project/requirements" >&2
  exit 1
fi

tmp="$(mktemp)"
cleanup() { rm -f "$tmp"; }
trap cleanup EXIT

node "$0.node" "${requirements_dirs[@]}" > "$tmp" 2>/dev/null || node - "${requirements_dirs[@]}" > "$tmp" <<'NODE'
const fs = require('fs');
const path = require('path');
const dirs = process.argv.slice(2);
function unquote(v) {
  v = (v || '').trim();
  if ((v.startsWith("'") && v.endsWith("'")) || (v.startsWith('"') && v.endsWith('"'))) {
    v = v.slice(1, -1);
  }
  return v.replace(/''/g, "'");
}
function field(text, name) {
  const re = new RegExp('^' + name.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + ':\\s*(.*)$', 'm');
  const m = text.match(re);
  return m ? unquote(m[1]) : '';
}
function blockScalar(text, marker, indent) {
  const m = marker.exec(text);
  if (!m) return '';
  const prefix = ' '.repeat(indent);
  const lines = text.slice(m.index + m[0].length).split('\n');
  const out = [];
  for (const line of lines) {
    if (line.startsWith(prefix)) {
      out.push(line.slice(indent));
    } else if (line === '') {
      out.push('');
    } else {
      break;
    }
  }
  return out.join('\n').replace(/\s+$/, '') + '\n';
}
function body(text) {
  return blockScalar(text, /^body: \|-\n/m, 2);
}
const seenIds = new Set();
const files = [];
for (const dir of dirs) {
  for (const file of fs.readdirSync(dir).filter(f => /\.ya?ml$/.test(f)).sort()) {
    files.push({ dir, file });
  }
}
const items = files.map(({ dir, file }) => {
  const text = fs.readFileSync(path.join(dir, file), 'utf8');
  const id = field(text, 'id') || file;
  if (seenIds.has(id)) return null;
  seenIds.add(id);
  return {
    file: path.join(dir, file),
    id,
    key: field(text, 'requirement_key'),
    cls: field(text, 'requirement_class'),
    order: Number(field(text, 'render_order') || '999999'),
    section: field(text, 'render_section'),
    status: field(text, 'status'),
    body: body(text),
  };
}).filter(Boolean).filter(i => i.status === 'active' && i.key && i.body)
  .sort((a,b) => {
    const rank = cls => cls === 'quality' ? 1 : cls === 'constraint' ? 2 : 0;
    return rank(a.cls) - rank(b.cls)
      || compareSection(a.section, b.section)
      || a.order - b.order
      || a.key.localeCompare(b.key);
  });

function sectionRank(section) {
  const m = (section || '').match(/^(\d+)\.(\d+)\b/);
  if (!m) return [999, 999, section || ''];
  return [Number(m[1]), Number(m[2]), section || ''];
}
function compareSection(a, b) {
  const ar = sectionRank(a);
  const br = sectionRank(b);
  return ar[0] - br[0] || ar[1] - br[1] || ar[2].localeCompare(br[2]);
}
function renderBody(markdown) {
  return markdown
    .split('\n')
    .filter(line => !/^## [345]\. /.test(line) && !/^### [345]\.\d+ /.test(line))
    .join('\n')
    .replace(/\s+$/, '') + '\n';
}
function print(s='') { process.stdout.write(s + '\n'); }
print('# pi-env Requirements');
print();
print('This document is generated reference output for requirements that have active coordination requirement items. Requirement coordination items are the preferred source of truth when present; update them first, then regenerate `REQUIREMENTS.md`. `REQUIREMENTS.md` is a secondary fallback source only for project or requirement areas that do not yet have coordination items.');
print();
print('Each rendered requirement has a stable public key such as `UC-001`, `CMD-004`, or `FS-010`. Coordination items may have timestamped item IDs, but generated documentation preserves these stable keys as the public requirement identifiers.');
print();
print('## 1. Product scope');
print();
print('`pi-env` provides a reusable Nix development shell and Bubblewrap launcher for `pi-coding-agent`. Each run operates on one selected project root, and that root is mounted read-write at `/workspace` inside the sandbox. `/workspace` is the sandbox path name, not a host-side multi-project workspace manager.');
print();
print('Coordination support must be implemented as an opt-in layer. It must not make `pi-start` create, claim, mark done, review, verify, close, commit, push, or otherwise mutate coordination state automatically. Any coordination helper that changes shared state must be explicit, inspectable, and backed by normal Git commits.');
print();
print('The project must keep two responsibilities separate:');
print();
print('- **Nix devshell/runtime:** reproducibly provide command-line tools on `PATH`.');
print('- **Bubblewrap launcher:** isolate the `pi` process from the host filesystem and environment while still allowing controlled access to the selected project root and selected Pi state.');
print();
print('## 2. History-derived intent');
print();
print('The git history establishes these product requirements:');
print();
print('1. The project started as a Nix flake providing a Pi agent runtime devshell.');
print('2. A startup command was added for running `pi` with an explicit tool allowlist and `--continue`.');
print('3. The launcher evolved from an ad-hoc script to flake-generated commands.');
print('4. The runtime became self-contained and no longer depends on a local `common-nix-runtime` flake.');
print('5. Bubblewrap isolation became the primary runtime boundary.');
print('6. Project-specific Pi sessions were intentionally exposed inside the sandbox, but only for the active project/path.');
print('7. The flake is intended for reuse by other projects through `lib.mkPiShell` or packages.');
print('8. Common Pi rules/skills/prompts/roles are imported from an external user-controlled directory, not shipped by `pi-env`.');
print('9. Host Git configuration is copied into the sandbox by default, but credentials, SSH keys, and host home are not mounted.');
print();
const topFor = cls => cls === 'quality' ? '## 4. Quality requirements' : cls === 'constraint' ? '## 5. Constraint requirements' : '## 3. Functional requirements';
let currentTop = '', currentSection = '';
for (const item of items) {
  const top = topFor(item.cls);
  if (top !== currentTop) {
    print(top); print(); currentTop = top; currentSection = '';
  }
  if (item.section && item.section !== currentSection) {
    print('### ' + item.section); print(); currentSection = item.section;
    if (item.section === '3.1 Workflow-level functional requirements') {
      print('Workflow-level requirements describe user goals that the detailed requirements must support. They are functional requirements with requirement kind `workflow`.');
      print();
    } else if (item.section === '4.2 Blackbox verification requirements') {
      print('These tests should be run from outside implementation internals where possible, using a temporary project and temporary host home/agent directories. A fake `pi` executable can be placed early on `PATH` to record argv, cwd, environment, and visible files.');
      print();
    }
  }
  process.stdout.write(renderBody(item.body) + '\n');
}
print('## 6. Coordination requirement item structure');
print();
print('Requirement coordination items live under root `requirements/` and keep item-ID filenames. Public requirement identity is stored in `requirement_key`; requirement classification is stored in `requirement_class`, `requirement_kind`, and `domain`. Requirement items are current-state records: they store one renderable top-level `body: |-` block and do not store embedded `current`, `events`, or `messages` history.');
print();
print('Required fields for functional, quality, and constraint requirement items:');
print();
print('```yaml');
print('schema: coordination-item/v1');
print('id: PIENV-FRQ-YYYYMMDD-HHMMSS-NNN');
print('type: functional-requirement');
print('requirement_key: CMD-004');
print('requirement_kind: detailed-behavior');
print('domain: commands');
print('status: active');
print('project: pi-env');
print('title: "`pi-bwrap` default invocation"');
print('source_refs:');
print('  - "REQUIREMENTS.md#CMD-004"');
print('related_workflows:');
print('  - UC-002');
print('related_requirements: []');
print('related_tests:');
print('  - TEST-005');
print('testable: yes');
print('testability_note: null');
print('body: |-');
print('  #### CMD-004 Example requirement');
print('');
print('  Requirement text...');
print('```');
print();
print('Workflow-level requirements should use:');
print();
print('```yaml');
print('type: functional-requirement');
print('requirement_key: UC-001');
print('requirement_kind: workflow');
print('domain: user-workflows');
print('```');
print();
print('Quality verification requirements should use:');
print();
print('```yaml');
print('type: quality-requirement');
print('requirement_key: TEST-001');
print('requirement_kind: blackbox-test');
print('domain: verification');
print('```');
print();
print('Constraint requirements should use:');
print();
print('```yaml');
print('type: constraint-requirement');
print('requirement_key: CRQ-001');
print('requirement_kind: architecture-boundary');
print('domain: constraints');
print('```');
print();
print('The top-level Markdown `body: |-` field for each requirement item must contain the renderable body for that requirement, including the stable heading, metadata, requirement text, acceptance criteria, and verification notes when applicable. Generated documentation renders stable requirement keys as the primary visible identifiers and may include coordination item IDs as secondary metadata.');
NODE

if [ -n "$output" ] && [ "$output" != "-" ]; then
  mkdir -p "$(dirname "$output")"
  cp "$tmp" "$output"
else
  cat "$tmp"
fi
