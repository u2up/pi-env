#!/usr/bin/env bash
set -euo pipefail

if [ -n "${PI_ENV_COORD_LIB:-}" ]; then
  # shellcheck source=/dev/null
  . "$PI_ENV_COORD_LIB"
else
  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
  # shellcheck source=agent-coord-lib.sh
  . "$script_dir/agent-coord-lib.sh"
fi

usage() {
  cat <<'USAGE'
agent-coord-list - list coordination items by type and optional status

Usage:
  agent-coord-list [options] TYPE [STATUS]

Arguments:
  TYPE          Item type to list, for example issues, todos, notes,
                decisions, requirements, functional-requirements,
                quality-requirements, or constraint-requirements.
                All requirement classes are stored under the single
                requirements directory; requirements lists functional,
                quality, and constraint requirement items.
  STATUS        Optional status filter, for example open, closed, or accepted

Options:
  --coord-dir DIR          Coordination clone; default: PI_COORD_DIR or .pi-env/coordination
  --repo-id REPO_ID        List issue items for one repository
  --all-repos              List issue items across all repositories and root issues
  --show-repo              Add issue repository id as the first output column
  --category CATEGORY      Only list issue items with this category
  --show-category          Add issue category as the first output column
  --group-by-category      Sort by issue category and add it as the first column
  -h, --help               Show this help

Output columns are tab-separated:
  item id, status, title

With --show-category or --group-by-category, output columns are:
  category, item id, status, title

With --all-repos, issue output includes a leading repo id column. Root issues
use '-' as the repo id.

Done issue titles include review and verification sub-status:
  title (reviewed:true|false, verified:true|false)
USAGE
}

coord_dir_opt=""
repo_id_arg=""
all_repos=0
show_repo=0
category_filter=""
show_category=0
group_by_category=0
positional=()

while [ "$#" -gt 0 ]; do
  case "$1" in
    --coord-dir)
      [ "$#" -ge 2 ] || coord_die "--coord-dir requires a value"
      coord_dir_opt="$2"
      shift 2
      ;;
    --repo-id)
      [ "$#" -ge 2 ] || coord_die "--repo-id requires a value"
      repo_id_arg="$2"
      shift 2
      ;;
    --all-repos)
      all_repos=1
      shift
      ;;
    --show-repo)
      show_repo=1
      shift
      ;;
    --category)
      [ "$#" -ge 2 ] || coord_die "--category requires a value"
      category_filter="$2"
      shift 2
      ;;
    --issue-type|--show-issue-type|--group-by-issue-type)
      coord_die "$1 has been removed; use category flags"
      ;;
    --show-category)
      show_category=1
      shift
      ;;
    --group-by-category)
      group_by_category=1
      show_category=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      while [ "$#" -gt 0 ]; do
        positional+=("$1")
        shift
      done
      ;;
    --*)
      coord_die "unknown option: $1"
      ;;
    *)
      positional+=("$1")
      shift
      ;;
  esac
done

if [ "${#positional[@]}" -lt 1 ]; then
  coord_die "item type is required"
fi

if [ "${#positional[@]}" -gt 2 ]; then
  coord_die "unexpected extra argument: ${positional[2]}"
fi

raw_item_type="${positional[0]}"
raw_item_type_lc="$(printf '%s' "$raw_item_type" | tr '[:upper:]' '[:lower:]')"
case "$raw_item_type_lc" in
  task|tasks)
    coord_die "$raw_item_type is not a coordination item type; use issues --category task"
    ;;
esac
list_all_requirement_classes=0
case "$raw_item_type_lc" in
  legacy-requirement|legacy-requirements|legacy_requirement|legacy_requirements|req|reqs)
    coord_die "generic REQ requirement listing has been removed; use functional-requirements, quality-requirements, or constraint-requirements"
    ;;
  requirement|requirements)
    item_type="requirement"
    list_all_requirement_classes=1
    ;;
  *)
    item_type="$(coord_item_type_canonical "$raw_item_type")"
    ;;
esac
case "$item_type" in
  issue|todo|note|decision|requirement|functional-requirement|quality-requirement|constraint-requirement)
    ;;
  *)
    coord_die "item type must be issues, todos, notes, decisions, requirements, functional-requirements, quality-requirements, or constraint-requirements"
    ;;
esac

status_filter="${positional[1]:-}"
status_filter_cmp="$(printf '%s' "$status_filter" | tr '[:upper:]' '[:lower:]')"

if [ "$show_category" = "1" ]; then
  if [ "$item_type" != "issue" ] || [ "$list_all_requirement_classes" = "1" ]; then
    coord_die "--show-category and --group-by-category can only be used with issue lists"
  fi
fi

if [ -n "$(coord_trim "$category_filter")" ]; then
  if [ "$item_type" != "issue" ] || [ "$list_all_requirement_classes" = "1" ]; then
    coord_die "--category can only filter issue lists"
  fi
  category_filter="$(coord_category_canonical "$category_filter")"
  [ -n "$category_filter" ] || coord_die "--category produced an empty category"
fi

if { [ -n "$repo_id_arg" ] || [ "$all_repos" = "1" ] || [ "$show_repo" = "1" ]; } \
  && { [ "$item_type" != "issue" ] || [ "$list_all_requirement_classes" = "1" ]; }; then
  coord_die "--repo-id, --all-repos, and --show-repo can only be used with issue lists"
fi
if [ -n "$repo_id_arg" ] && [ "$all_repos" = "1" ]; then
  coord_die "--repo-id and --all-repos cannot be used together"
fi

coord_dir="$(coord_resolve_dir "$coord_dir_opt")"

repo_filter=""
if [ "$item_type" = "issue" ] && [ "$list_all_requirement_classes" != "1" ]; then
  if [ "$all_repos" = "1" ]; then
    show_repo=1
  elif [ -n "$repo_id_arg" ]; then
    repo_filter="$(coord_resolve_repo_id "$repo_id_arg" "$coord_dir")"
  elif [ -d "$coord_dir/repos" ]; then
    repo_filter="$(coord_resolve_repo_id "" "$coord_dir" 2>/dev/null || true)"
  fi
fi

cd "$coord_dir"

tab="$(printf '\t')"
rows_file=""
if [ "$group_by_category" = "1" ]; then
  rows_file="$(mktemp)"
  trap 'rm -f "$rows_file"' EXIT
fi

while IFS= read -r file; do
  [ -n "$file" ] || continue

  raw_type="$(coord_item_value "$file" type || true)"
  [ -n "$raw_type" ] || continue
  file_repo="-"
  case "$file" in
    repos/*/issues/*)
      file_repo="${file#repos/}"
      file_repo="${file_repo%%/*}"
      ;;
  esac
  if [ -n "$repo_filter" ] && [ "$file_repo" != "$repo_filter" ]; then
    continue
  fi
  file_type="$(coord_item_type_canonical "$raw_type")"
  if [ "$list_all_requirement_classes" = "1" ]; then
    case "$file_type" in
      functional-requirement|quality-requirement|constraint-requirement)
        ;;
      *)
        continue
        ;;
    esac
  else
    [ "$file_type" = "$item_type" ] || continue
  fi

  status="$(coord_item_value "$file" status || true)"
  [ -n "$status" ] || status="unknown"
  status_cmp="$(printf '%s' "$status" | tr '[:upper:]' '[:lower:]')"
  if [ -n "$status_filter" ] && [ "$status_cmp" != "$status_filter_cmp" ]; then
    continue
  fi

  category="$(coord_item_value "$file" category || true)"
  if [ -z "$(coord_trim "$category")" ]; then
    category="uncategorized"
  else
    category="$(coord_category_canonical "$category")"
    [ -n "$category" ] || category="uncategorized"
  fi
  if [ -n "$category_filter" ] && [ "$category" != "$category_filter" ]; then
    continue
  fi

  id="$(coord_item_value "$file" id || true)"
  if [ -z "$id" ]; then
    id="$(basename "$file")"
    id="${id%.yaml}"
    id="${id%.yml}"
    id="${id%.md}"
  fi

  title="$(coord_item_value "$file" title || true)"
  if [ -z "$title" ]; then
    title="$(grep -m 1 '^# ' "$file" | sed 's/^# //' || true)"
  fi
  [ -n "$title" ] || title="(untitled)"

  if [ "$file_type" = "issue" ] && [ "$status_cmp" = "done" ]; then
    reviewed="false"
    verified="false"
    if coord_item_flag_true "$file" reviewed; then
      reviewed="true"
    fi
    if coord_item_flag_true "$file" verified; then
      verified="true"
    fi
    title="$title (reviewed:$reviewed, verified:$verified)"
  fi

  if [ "$show_repo" = "1" ] && [ "$show_category" = "1" ]; then
    row="${file_repo}	${category}	${id}	${status}	${title}"
  elif [ "$show_repo" = "1" ]; then
    row="${file_repo}	${id}	${status}	${title}"
  elif [ "$show_category" = "1" ]; then
    row="${category}	${id}	${status}	${title}"
  else
    row="${id}	${status}	${title}"
  fi

  if [ "$group_by_category" = "1" ]; then
    printf '%s\n' "$row" >>"$rows_file"
  else
    printf '%s\n' "$row"
  fi
done < <(coord_item_find_files)

if [ "$group_by_category" = "1" ] && [ -n "$rows_file" ]; then
  if [ "$show_repo" = "1" ]; then
    sort -t "$tab" -k2,2 -k1,1 -k3,3 "$rows_file"
  else
    sort -t "$tab" -k1,1 -k2,2 "$rows_file"
  fi
fi
