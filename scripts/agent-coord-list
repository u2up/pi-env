#!/usr/bin/env bash
set -euo pipefail

if [ -n "${PI_ENV_COORD_LIB:-}" ]; then
  # shellcheck source=/dev/null
  . "$PI_ENV_COORD_LIB"
else
  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
  # shellcheck source=agent-coord-lib.sh
  . "$script_dir/agent-coord-lib.sh"
fi

usage() {
  cat <<'USAGE'
agent-coord-list - list coordination items by type and optional status

Usage:
  agent-coord-list [options] TYPE [STATUS]

Arguments:
  TYPE          Item type to list, for example issues, todos, notes,
                decisions, requirements, functional-requirements,
                quality-requirements, or constraint-requirements.
                All requirement classes are stored under the single
                requirements directory; requirements lists functional,
                quality, constraint, and legacy requirement items;
                legacy-requirements lists only generic legacy requirement
                items.
  STATUS        Optional status filter, for example open, closed, or accepted

Options:
  --coord-dir DIR          Coordination clone; default: PI_COORD_DIR, .pi-env/coordination, or legacy ./coordination
  --issue-type TYPE        Only list issue items with this category
  --show-issue-type        Add issue category as the first output column
  --group-by-issue-type    Sort by issue category and add it as the first column
  -h, --help               Show this help

Output columns are tab-separated:
  item id, status, title

With --show-issue-type or --group-by-issue-type, output columns are:
  issue type, item id, status, title

Done issue titles include review and verification sub-status:
  title (reviewed:true|false, verified:true|false)
USAGE
}

coord_dir_opt=""
issue_type_filter=""
show_issue_type=0
group_by_issue_type=0
positional=()

while [ "$#" -gt 0 ]; do
  case "$1" in
    --coord-dir)
      [ "$#" -ge 2 ] || coord_die "--coord-dir requires a value"
      coord_dir_opt="$2"
      shift 2
      ;;
    --issue-type)
      [ "$#" -ge 2 ] || coord_die "--issue-type requires a value"
      issue_type_filter="$2"
      shift 2
      ;;
    --show-issue-type)
      show_issue_type=1
      shift
      ;;
    --group-by-issue-type)
      group_by_issue_type=1
      show_issue_type=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      while [ "$#" -gt 0 ]; do
        positional+=("$1")
        shift
      done
      ;;
    --*)
      coord_die "unknown option: $1"
      ;;
    *)
      positional+=("$1")
      shift
      ;;
  esac
done

if [ "${#positional[@]}" -lt 1 ]; then
  coord_die "item type is required"
fi

if [ "${#positional[@]}" -gt 2 ]; then
  coord_die "unexpected extra argument: ${positional[2]}"
fi

raw_item_type="${positional[0]}"
raw_item_type_lc="$(printf '%s' "$raw_item_type" | tr '[:upper:]' '[:lower:]')"
list_all_requirement_classes=0
case "$raw_item_type_lc" in
  legacy-requirement|legacy-requirements|legacy_requirement|legacy_requirements)
    item_type="requirement"
    ;;
  requirement|requirements|req|reqs)
    item_type="requirement"
    list_all_requirement_classes=1
    ;;
  *)
    item_type="$(coord_item_type_canonical "$raw_item_type")"
    ;;
esac
case "$item_type" in
  issue|todo|note|decision|requirement|functional-requirement|quality-requirement|constraint-requirement)
    ;;
  *)
    coord_die "item type must be issues, todos, notes, decisions, requirements, legacy-requirements, functional-requirements, quality-requirements, or constraint-requirements"
    ;;
esac

status_filter="${positional[1]:-}"
status_filter_cmp="$(printf '%s' "$status_filter" | tr '[:upper:]' '[:lower:]')"

if [ "$show_issue_type" = "1" ]; then
  if [ "$item_type" != "issue" ] || [ "$list_all_requirement_classes" = "1" ]; then
    coord_die "--show-issue-type and --group-by-issue-type can only be used with issue lists"
  fi
fi

if [ -n "$(coord_trim "$issue_type_filter")" ]; then
  if [ "$item_type" != "issue" ] || [ "$list_all_requirement_classes" = "1" ]; then
    coord_die "--issue-type can only filter issue lists"
  fi
  issue_type_filter="$(coord_issue_type_canonical "$issue_type_filter")"
  [ -n "$issue_type_filter" ] || coord_die "--issue-type produced an empty category"
fi

coord_dir="$(coord_resolve_dir "$coord_dir_opt")"
cd "$coord_dir"

tab="$(printf '\t')"
rows_file=""
if [ "$group_by_issue_type" = "1" ]; then
  rows_file="$(mktemp)"
  trap 'rm -f "$rows_file"' EXIT
fi

while IFS= read -r file; do
  [ -n "$file" ] || continue

  raw_type="$(coord_item_value "$file" type || true)"
  [ -n "$raw_type" ] || continue
  file_type="$(coord_item_type_canonical "$raw_type")"
  if [ "$list_all_requirement_classes" = "1" ]; then
    case "$file_type" in
      requirement|functional-requirement|quality-requirement|constraint-requirement)
        ;;
      *)
        continue
        ;;
    esac
  else
    [ "$file_type" = "$item_type" ] || continue
  fi

  status="$(coord_item_value "$file" status || true)"
  [ -n "$status" ] || status="unknown"
  status_cmp="$(printf '%s' "$status" | tr '[:upper:]' '[:lower:]')"
  if [ -n "$status_filter" ] && [ "$status_cmp" != "$status_filter_cmp" ]; then
    continue
  fi

  issue_type="$(coord_item_value "$file" issue_type || true)"
  if [ -z "$(coord_trim "$issue_type")" ]; then
    issue_type="uncategorized"
  else
    issue_type="$(coord_issue_type_canonical "$issue_type")"
    [ -n "$issue_type" ] || issue_type="uncategorized"
  fi
  if [ -n "$issue_type_filter" ] && [ "$issue_type" != "$issue_type_filter" ]; then
    continue
  fi

  id="$(coord_item_value "$file" id || true)"
  if [ -z "$id" ]; then
    id="$(basename "$file")"
    id="${id%.yaml}"
    id="${id%.yml}"
    id="${id%.md}"
  fi

  title="$(coord_item_value "$file" title || true)"
  if [ -z "$title" ]; then
    title="$(grep -m 1 '^# ' "$file" | sed 's/^# //' || true)"
  fi
  [ -n "$title" ] || title="(untitled)"

  if [ "$file_type" = "issue" ] && [ "$status_cmp" = "done" ]; then
    reviewed="false"
    verified="false"
    if coord_item_flag_true "$file" reviewed; then
      reviewed="true"
    fi
    if coord_item_flag_true "$file" verified; then
      verified="true"
    fi
    title="$title (reviewed:$reviewed, verified:$verified)"
  fi

  if [ "$show_issue_type" = "1" ]; then
    row="${issue_type}	${id}	${status}	${title}"
  else
    row="${id}	${status}	${title}"
  fi

  if [ "$group_by_issue_type" = "1" ]; then
    printf '%s\n' "$row" >>"$rows_file"
  else
    printf '%s\n' "$row"
  fi
done < <(coord_item_find_files)

if [ "$group_by_issue_type" = "1" ] && [ -n "$rows_file" ]; then
  sort -t "$tab" -k1,1 -k2,2 "$rows_file"
fi
