#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
flake_ref="${PI_ENV_FLAKE:-$script_dir}"
raw=0
args=()

usage() {
  cat <<'USAGE'
pi-env - enter pi-env and run Pi for the current project

Usage:
  pi-env [--flake REF] [pi args...]
  pi-env [--flake REF] --raw -- [pi args...]
  pi-env --help

Default mode delegates to pi-start, which applies the standard tools,
--continue, sandbox policy, and default role-manager loading.
Raw mode delegates to pi-bwrap for fully custom Pi arguments.

Direct checkout mode uses nix develop REF -c pi-env when pi-start and
pi-bwrap are not already on PATH. REF defaults to this checkout, or
PI_ENV_FLAKE when set.
USAGE
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    -h|--help)
      usage
      exit 0
      ;;
    --flake)
      shift
      if [ "$#" -eq 0 ]; then
        echo "pi-env: --flake requires an argument" >&2
        exit 2
      fi
      flake_ref="$1"
      shift
      ;;
    --flake=*)
      flake_ref="${1#--flake=}"
      shift
      ;;
    --raw)
      raw=1
      args+=("$1")
      shift
      if [ "${1:-}" = "--" ]; then
        args+=("$1")
        shift
      fi
      break
      ;;
    --)
      shift
      break
      ;;
    *)
      break
      ;;
  esac
done

args+=("$@")

if command -v pi-start >/dev/null 2>&1 && command -v pi-bwrap >/dev/null 2>&1; then
  if [ "$raw" = "1" ]; then
    if [ "${args[0]:-}" = "--raw" ]; then
      args=("${args[@]:1}")
    fi
    if [ "${args[0]:-}" = "--" ]; then
      args=("${args[@]:1}")
    fi
    exec pi-bwrap -- "${args[@]}"
  fi
  exec pi-start "${args[@]}"
fi

if ! command -v nix >/dev/null 2>&1; then
  echo "pi-env: nix was not found on PATH and pi-env commands are unavailable." >&2
  echo "Install Nix, enter a pi-env devshell, or add pi-start/pi-bwrap to PATH." >&2
  exit 127
fi

exec nix develop "$flake_ref" -c pi-env "${args[@]}"
